---
// Selected-Work carousel — reworked as a 3D image canvas. The featured
// project's hero image is wrapped over a lit, cursor-parallax card
// (public/js/hero-canvas.js); Prev/Next and the arrow keys step through the
// set. Light, editorial, on the grid — replaces the previous full-bleed dark
// image carousel.

import Grid from './Grid.astro';
import imageManifest from '../content/projects-images.json';

function heroFor(slug: string, heroSlug: string) {
  const manifest = (imageManifest as Record<string, { images: any[] }>)[slug];
  const img = manifest?.images.find((i) => i.slug === heroSlug);
  if (!img) return null;
  return { src: img.src.replace('-2400.webp', '-1200.webp'), aspect: img.aspect as number };
}

const PROJECTS = [
  { name: 'Mantis',                  year: 2026, discipline: 'Product Design',            slug: 'mantis',               hero: heroFor('mantis', '04-final-hero') },
  { name: 'Wave',                    year: 2026, discipline: 'Product Design',            slug: 'wave',                 hero: heroFor('wave', '03-final-hero') },
  { name: 'Gravity Wave Backgammon', year: 2024, discipline: 'Product Design',            slug: 'backgammon',           hero: heroFor('backgammon', '07-final-hero') },
  { name: 'LUMI',                    year: 2023, discipline: 'Critical / Product Design', slug: 'lumi',                 hero: heroFor('lumi', '04-final-hero') },
  { name: 'YourPAL',                 year: 2023, discipline: 'App Design / UX·UI',        slug: 'yourpal',              hero: heroFor('yourpal', '04-final-hero') },
  { name: 'Spider-209',              year: 2022, discipline: 'Product Design',            slug: 'spider-209',           hero: heroFor('spider-209', '04-final') },
  { name: 'Universal Phone Case',    year: 2022, discipline: 'Product Design',            slug: 'universal-phone-case', hero: heroFor('universal-phone-case', '07-final-hero') },
];

const clientData = PROJECTS.map((p) => ({
  name: p.name, year: p.year, discipline: p.discipline, href: `/work/${p.slug}/`, hero: p.hero,
}));
const N = PROJECTS.length;
---
<section class="carousel-section" aria-labelledby="carousel-h">
  <Grid class="carousel">
    <span class="label c-kicker reveal">02 &mdash; Selected Work</span>
    <h2 id="carousel-h" class="sr-only">Selected work</h2>

    <div class="c-text reveal">
      <span class="c-index" id="cIndex" aria-live="polite">01 / {String(N).padStart(2, '0')}</span>
      <h3 class="c-name" id="cName">{PROJECTS[0].name}</h3>
      <div class="c-meta" id="cMeta">{PROJECTS[0].year} &middot; {PROJECTS[0].discipline}</div>
      <a class="c-link" id="cLink" href={`/work/${PROJECTS[0].slug}/`}>View project &rarr;</a>

      <div class="c-controls">
        <button class="c-btn" id="cPrev" aria-label="Previous project">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M14.5 6 L9.5 12 L14.5 18" stroke="currentColor" stroke-width="1.25" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="c-btn" id="cNext" aria-label="Next project">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M9.5 6 L14.5 12 L9.5 18" stroke="currentColor" stroke-width="1.25" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <div class="c-canvas-col reveal" id="carousel" role="region" aria-roledescription="carousel" aria-label="Featured projects" tabindex="0">
      <div class="c-cell">
        <canvas class="c-canvas" id="cCanvas" aria-hidden="true"></canvas>
      </div>
    </div>

    <a class="c-foot reveal" href="/work/">All work &rarr;</a>
  </Grid>
</section>

<script type="application/json" id="cData" is:inline set:html={JSON.stringify(clientData)}></script>

<style>
  .carousel-section { position: relative; background: var(--bg); z-index: 2;
    padding-block: clamp(64px, 12vh, 140px); }
  /* :global — targets the <Grid> root element (no component scope hash). */
  :global(.carousel) { row-gap: clamp(28px, 4vh, 48px); align-items: center; }

  .c-kicker { grid-column: 1 / -1; display: block; }

  .c-text { grid-column: 1 / -1; display: flex; flex-direction: column; align-items: flex-start; }
  .c-index { font-family: var(--sans); font-weight: 500; font-size: 12px; letter-spacing: 0.22em;
    color: var(--text-faint); font-variant-numeric: tabular-nums; margin-bottom: 18px; }
  .c-name { font-family: var(--serif); font-weight: 400; font-size: clamp(34px, 4.6vw, 64px);
    line-height: 1.04; color: var(--text); margin: 0 0 16px; }
  .c-meta { font-family: var(--sans); font-weight: 500; font-size: 12px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--text-quiet); margin-bottom: 26px; }
  .c-link { font-family: var(--sans); font-weight: 500; font-size: 12px; letter-spacing: 0.20em;
    text-transform: uppercase; color: var(--text); padding-bottom: 3px;
    border-bottom: 1px solid var(--text);
    transition: color var(--dur-hover) var(--ease-out), border-color var(--dur-hover) var(--ease-out); }
  .c-link:hover { color: var(--accent); border-bottom-color: var(--accent); }

  .c-controls { display: flex; gap: 14px; margin-top: clamp(28px, 4vh, 44px); }
  .c-btn { width: 46px; height: 46px; border-radius: 50%; border: 1px solid var(--rule);
    color: var(--text); display: grid; place-items: center;
    transition: border-color var(--dur-hover) var(--ease-out), color var(--dur-hover) var(--ease-out); }
  .c-btn:hover { border-color: var(--accent); color: var(--accent); }

  .c-canvas-col { grid-column: 1 / -1; }
  .c-cell { position: relative; width: 100%; aspect-ratio: 4 / 3; max-height: 78vh;
    transition: aspect-ratio 0.55s var(--ease-out); }
  .c-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block;
    opacity: 0; transition: opacity 0.45s var(--ease-out); }
  @media (prefers-reduced-motion: reduce) {
    .c-cell { transition: none; }
    .c-canvas { transition: none; opacity: 1; }
  }

  .c-foot { grid-column: 1 / -1; justify-self: start; font-family: var(--sans); font-weight: 500;
    font-size: 12px; letter-spacing: 0.20em; text-transform: uppercase; color: var(--text);
    padding-bottom: 3px; border-bottom: 1px solid var(--text); margin-top: clamp(20px, 3vh, 36px);
    transition: color var(--dur-hover) var(--ease-out), border-color var(--dur-hover) var(--ease-out); }
  .c-foot:hover { color: var(--accent); border-bottom-color: var(--accent); }

  /* Tablet+ — text left, canvas right. */
  @media (min-width: 768px) {
    .c-kicker { grid-column: 1 / 5; }
    .c-text   { grid-column: 1 / 4; }
    .c-canvas-col { grid-column: 4 / 9; }
    .c-foot   { grid-column: 1 / 5; }
  }
  @media (min-width: 1200px) {
    .c-kicker { grid-column: 1 / 6; }
    .c-text   { grid-column: 1 / 5; }
    .c-canvas-col { grid-column: 6 / 13; }
    .c-foot   { grid-column: 1 / 6; }
  }
</style>

<script is:inline type="module">
  import { mountHeroCanvas } from '/js/hero-canvas.js';

  const data = JSON.parse(document.getElementById('cData').textContent);
  const N = data.length;
  const canvas = document.getElementById('cCanvas');
  const nameEl = document.getElementById('cName');
  const metaEl = document.getElementById('cMeta');
  const linkEl = document.getElementById('cLink');
  const idxEl  = document.getElementById('cIndex');
  const prev   = document.getElementById('cPrev');
  const next   = document.getElementById('cNext');
  const region = document.getElementById('carousel');

  const cell = document.querySelector('.c-cell');
  const api = mountHeroCanvas(canvas, {
    camZ: 6.4, fill: 0.92,
    onAspect: (a) => { cell.style.aspectRatio = String(a); },
    onShown: () => { canvas.style.opacity = '1'; },   // fade in once loaded
  });
  let cur = 0;

  function go(i) {
    cur = (i + N) % N;
    const p = data[cur];
    canvas.style.opacity = '0';   // crossfade: fade out, fade back in on load
    api.show(p.hero);
    nameEl.textContent = p.name;
    metaEl.innerHTML = `${p.year} &middot; ${p.discipline}`;
    linkEl.setAttribute('href', p.href);
    idxEl.textContent = `${String(cur + 1).padStart(2, '0')} / ${String(N).padStart(2, '0')}`;
  }
  go(0);

  next.addEventListener('click', () => go(cur + 1));
  prev.addEventListener('click', () => go(cur - 1));
  region.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') { e.preventDefault(); go(cur + 1); }
    if (e.key === 'ArrowLeft')  { e.preventDefault(); go(cur - 1); }
  });
</script>
