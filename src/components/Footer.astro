---
// Minimal closing band. Ported from prototypes/hero/index.html — the email
// is the surface; the nav links are repeated small; copyright is quiet.
//
// All caps run through the .label / Raleway 500 / 0.22em system so the
// footer reads as one with the nav and the page kickers.
---
<footer aria-label="Site footer">
  <div class="footer-inner">
    <div class="footer-contact reveal">
      <span class="label">Get in touch</span>
      <a class="footer-email" href="mailto:court@courtgranville.com">court@courtgranville.com</a>
    </div>
    <nav class="footer-links" aria-label="Footer">
      <a href="/work/">Work</a>
      <a href="#">Blog</a>
      <a href="#">About</a>
      <a href="#">Contact</a>
    </nav>
    <div class="footer-copyright">&copy; 2026 Court Granville</div>
  </div>
</footer>

<style>
  footer {
    background: var(--bg);
    border-top: 1px solid var(--rule);
    padding: clamp(56px, 9vh, 96px) var(--outer) 32px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'contact links'
      'copyright copyright';
    gap: 60px 40px;
    align-items: end;
  }
  .footer-contact { grid-area: contact; }
  .footer-contact .label { display: block; margin-bottom: 12px; }

  .footer-email {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 32px);
    color: var(--text);
    transition: color var(--dur-hover) var(--ease-out);
  }
  .footer-email:hover { color: var(--accent); }

  .footer-links {
    grid-area: links;
    display: flex;
    gap: 28px;
  }
  .footer-links a {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--text-quiet);
    transition: color var(--dur-hover) var(--ease-out);
  }
  .footer-links a:hover { color: var(--accent); }

  .footer-copyright {
    grid-area: copyright;
    margin-top: 44px;
    padding-top: 22px;
    border-top: 1px solid var(--rule);
    font-family: var(--sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr;
      grid-template-areas: 'contact' 'links' 'copyright';
      gap: 36px;
    }
  }
</style>
