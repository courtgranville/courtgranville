---
// The 12 / 8 / 4 column container — the single grid every page is built on.
// Children take a named track (see global.css `.t-*`) or a documented
// `grid-column` range. `--cols`, `--gutter`, `--outer` come from tokens.css
// and shift at breakpoints, so one `<Grid>` adapts without per-component media
// queries. The grid is centred within `--content-max`; nothing breaks out to
// the viewport edge any more (the old `bleed` mode is gone — use the Wide/Full
// tracks instead).

export interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { as: Tag = 'div', class: className = '' } = Astro.props;
---
<Tag class:list={['grid', className]}>
  <slot />
</Tag>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    column-gap: var(--gutter);
    width: 100%;
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--outer);
  }
</style>
