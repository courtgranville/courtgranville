---
// The CG WebGL particle hero — verbatim transplant of the proven system from
// prototypes/hero/index.html. Mounted on the homepage as the first screen.
//
// Astro convention: vanilla `<script is:inline type="module">` so the existing
// CDN import map (declared in Layout.astro head) resolves the `three`,
// `three/addons/`, `lil-gui` and `lenis` specifiers without Vite's bundler.
// This is the right way to satisfy the spec's `client:load` intent in plain
// vanilla — Astro `client:load` is a framework-island directive.
//
// CONFIG is locked to Court's tuned values per homepage-build-spec §0 — do
// not change values here without explicit direction. The GUI stays available
// for future tuning. The scroll-cue and hero canvas markup match the existing
// build so visual rendering is identical.
//
// Hero-loaded handoff: on load-in completion the hero dispatches a
// `hero:loaded` CustomEvent on `window`; in Phase 1 the local script also
// adds `.in` to the in-page nav and scroll-cue directly so the homepage
// renders identically to the existing prototype.
---
<canvas id="c" aria-hidden="true"></canvas>

<section class="hero-section" aria-label="Hero">
  <!-- A small text complement to the 3D, supplied by the page. It sits over the
       empty lower-left; the CG glyph reads in the centre of the field. -->
  <div class="hero-overlay"><slot /></div>
  <div class="scroll-cue" id="scrollCue">
    SCROLL
    <span class="arrow">&darr;</span>
  </div>
</section>

<style>
  /* The canvas is fixed; content sections in normal flow scroll over it. */
  #c {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 1;
  }

  .hero-section {
    position: relative;
    height: 100vh;
    background: transparent;
    z-index: 2;
  }

  /* Small text complement, anchored to the lower-left of the first screen. */
  .hero-overlay {
    position: absolute;
    left: var(--outer);
    bottom: clamp(72px, 12vh, 132px);
    max-width: 38ch;
    pointer-events: none; /* re-enabled on interactive children below */
  }
  .hero-overlay :global(a),
  .hero-overlay :global(button) { pointer-events: auto; }

  .scroll-cue {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--sans);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0;
    text-align: center;
    transition: opacity 600ms var(--ease-out);
    pointer-events: none;
  }
  .scroll-cue.in { opacity: 0.55; }
  .scroll-cue .arrow {
    display: block;
    margin-top: 8px;
    font-size: 12px;
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); opacity: 0.55; }
    50%      { transform: translateY(6px); opacity: 0.95; }
  }

  /* lil-gui chrome — keep the GUI dark so it does not clash with the light
   * page when opened for tuning. */
  :global(.lil-gui) {
    --background-color: #101218;
    --widget-color: #1c2029;
    --hover-color: #272d3a;
    --focus-color: #303746;
    --text-color: #cfd3dc;
    --title-background-color: #070a12;
    --font-size: 11px;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue .arrow { animation: none; }
  }
</style>

<script is:inline type="module">
  /* eslint-disable */
  import * as THREE from 'three';
  import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
  import { RenderPass }     from 'three/addons/postprocessing/RenderPass.js';
  import { ShaderPass }     from 'three/addons/postprocessing/ShaderPass.js';
  import { RGBShiftShader } from 'three/addons/shaders/RGBShiftShader.js';
  import GUI   from 'lil-gui';

  const TAU = Math.PI * 2;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ─────────────────────────────────────────────────────────────────────────
  // CONFIG — locked to Court's tuned values (homepage-build-spec §0).
  // ─────────────────────────────────────────────────────────────────────────
  const CONFIG = {
    scene: {
      bgColor:            '#FFFFFF',
      cameraDistance:     15,
      cameraFov:          32,
      cameraDriftEnabled: false,
      cameraDriftAmp:     0,
      cameraDriftSpeed:   0,
    },
    glyph: {
      text:           'CG',
      worldHeight:    3.1,
      depth:          0.39,
      canvasWidth:    2400,
      fontWeight:     700,
      alphaThreshold: 80,
    },
    particles: {
      count:              140000,
      contourBoost:       0,
      baseSize:           0.032,
      sizeVariance:       0.22,
      inkColor:           '#161616',
      inkLightnessVar:    0,
      opacity:            1,
      depthFade:          0,
    },
    physics: {
      springK:         15,
      damping:         0.99,
      maxVel:          12.1,
      maxDisplacement: 4,
      ambientMode:     'off',
      ambientAmp:      0.003,
      ambientFreq:     0.11,
    },
    pointer: {
      mode:      'repel',
      radius:    0.27,
      strength:  25,
      falloff:   'smoothstep',
      smoothing: 0.59,
    },
    rotation: {
      mode:           'continuous',
      speed:          reducedMotion ? 0 : 0.06,
      oscAngle:       0.55,
      oscFreq:        0.32,
      parallax:       false,
      parallaxAmount: 0.06,
      parallaxLerp:   0.05,
    },
    loadIn: {
      duration:    1.6,
      stagger:     0.7,
      staggerMode: 'leftToRight',
      easing:      'easeOutCubic',
      startVolume: 7,
      uiFadeDelay: 0.15,
    },
    post: {
      grain:               0,
      vignette:            0,
      chromaticAberration: 0,
    },
  };

  // Lighten the particle count on small / low-power screens — 140k is tuned for
  // desktop; phones hold 60fps far better at ~55k.
  if (window.matchMedia('(max-width: 768px)').matches) {
    CONFIG.particles.count = 55000;
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Helpers
  // ─────────────────────────────────────────────────────────────────────────
  const easings = {
    linear:         t => t,
    easeOutCubic:   t => 1 - Math.pow(1 - t, 3),
    easeOutExpo:    t => t >= 1 ? 1 : 1 - Math.pow(2, -10 * t),
    easeInOutCubic: t => t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2,
  };

  function pickIndices(n, k) {
    k = Math.min(n, k);
    const arr = new Uint32Array(n);
    for (let i = 0; i < n; i++) arr[i] = i;
    for (let i = 0; i < k; i++) {
      const j = i + ((Math.random() * (n - i)) | 0);
      const t = arr[i]; arr[i] = arr[j]; arr[j] = t;
    }
    return arr.subarray(0, k);
  }

  // ─────────────────────────────────────────────────────────────────────────
  // GlyphSampler
  // ─────────────────────────────────────────────────────────────────────────
  class GlyphSampler {
    async sample(cfg) {
      await document.fonts.load(`${cfg.glyph.fontWeight} 96px "Playfair Display"`);
      await document.fonts.ready;

      const w = cfg.glyph.canvasWidth;
      const h = Math.round(w * 0.72);
      const cnv = document.createElement('canvas');
      cnv.width = w; cnv.height = h;
      const ctx = cnv.getContext('2d', { willReadFrequently: true });
      ctx.fillStyle = '#ffffff';
      ctx.textBaseline = 'alphabetic';

      let fontSize = Math.round(h * 0.96);
      ctx.font = `${cfg.glyph.fontWeight} ${fontSize}px "Playfair Display"`;
      let m = ctx.measureText(cfg.glyph.text);
      if (m.width > w * 0.94) {
        fontSize = Math.floor(fontSize * (w * 0.94) / m.width);
        ctx.font = `${cfg.glyph.fontWeight} ${fontSize}px "Playfair Display"`;
        m = ctx.measureText(cfg.glyph.text);
      }
      const ascent  = m.actualBoundingBoxAscent;
      const descent = m.actualBoundingBoxDescent;
      const drawX = (w - m.width) / 2;
      const drawY = h / 2 + (ascent - descent) / 2;
      ctx.fillText(cfg.glyph.text, drawX, drawY);

      const img = ctx.getImageData(0, 0, w, h).data;
      const thresh = cfg.glyph.alphaThreshold;
      const filled = new Uint8Array(w * h);
      for (let y = 0; y < h; y++) {
        const row = y * w;
        for (let x = 0; x < w; x++) {
          if (img[(row + x) * 4 + 3] > thresh) filled[row + x] = 1;
        }
      }

      let minX = w, minY = h, maxX = -1, maxY = -1;
      for (let y = 0; y < h; y++) {
        const row = y * w;
        for (let x = 0; x < w; x++) {
          if (filled[row + x]) {
            if (x < minX) minX = x;
            if (x > maxX) maxX = x;
            if (y < minY) minY = y;
            if (y > maxY) maxY = y;
          }
        }
      }
      if (maxX < 0) throw new Error('GlyphSampler: no pixels drawn — is Playfair Display loaded?');
      const cx = (minX + maxX) / 2;
      const cy = (minY + maxY) / 2;
      const scale = cfg.glyph.worldHeight / (maxY - minY);

      const all     = [];
      const contour = [];
      for (let y = minY; y <= maxY; y++) {
        const row = y * w;
        for (let x = minX; x <= maxX; x++) {
          if (!filled[row + x]) continue;
          const wx =  (x - cx) * scale;
          const wy = -(y - cy) * scale;
          all.push(wx, wy);
          const up    = y > 0     ? filled[row - w + x] : 0;
          const down  = y < h - 1 ? filled[row + w + x] : 0;
          const left  = x > 0     ? filled[row + x - 1] : 0;
          const right = x < w - 1 ? filled[row + x + 1] : 0;
          if (!(up && down && left && right)) {
            contour.push(wx, wy);
          }
        }
      }
      return { all, contour };
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // ParticleSystem
  // ─────────────────────────────────────────────────────────────────────────
  const VERT = `
  attribute float aSeed;
  attribute float aSizeMul;
  attribute float aLight;
  uniform float uBaseSize;
  uniform float uSizeScale;
  uniform float uFadeNear;
  uniform float uFadeFar;
  uniform float uDepthFade;
  varying float vFade;
  varying float vLight;
  void main() {
    vec4 mv = modelViewMatrix * vec4(position, 1.0);
    gl_PointSize = uBaseSize * aSizeMul * (uSizeScale / -mv.z);
    gl_Position = projectionMatrix * mv;
    float vd = -mv.z;
    float t = clamp((vd - uFadeNear) / max(uFadeFar - uFadeNear, 0.0001), 0.0, 1.0);
    vFade  = t * uDepthFade;
    vLight = aLight;
  }
  `;
  const FRAG = `
  precision highp float;
  varying float vFade;
  varying float vLight;
  uniform vec3 uInkColor;
  uniform vec3 uBgColor;
  uniform float uLightnessVar;
  uniform float uOpacity;
  void main() {
    vec2 c = gl_PointCoord - 0.5;
    float r = length(c) * 2.0;
    if (r >= 1.0) discard;
    float a = smoothstep(1.0, 0.25, r);
    vec3 ink = clamp(uInkColor + vec3(vLight * uLightnessVar), 0.0, 1.0);
    vec3 col = mix(ink, uBgColor, vFade);
    gl_FragColor = vec4(col, a * uOpacity);
  }
  `;

  class ParticleSystem {
    constructor(samples, cfg) {
      const nAll     = samples.all.length / 2;
      const nContour = samples.contour.length / 2;

      const wantContour = Math.min(nContour, Math.round(cfg.particles.count * cfg.particles.contourBoost));
      const wantMain    = Math.max(0, cfg.particles.count - wantContour);
      const idxMain     = pickIndices(nAll,     wantMain);
      const idxContour  = pickIndices(nContour, wantContour);
      const count = idxMain.length + idxContour.length;

      const positions = new Float32Array(count * 3);
      const home      = new Float32Array(count * 3);
      const seed      = new Float32Array(count);
      const sizeMul   = new Float32Array(count);
      const light     = new Float32Array(count);
      this.vel        = new Float32Array(count * 3);

      const v     = cfg.particles.sizeVariance;
      const depth = cfg.glyph.depth;
      let w = 0;
      const writePoint = (sx, sy) => {
        const i3 = w * 3;
        const z = (Math.random() - 0.5) * depth;
        home[i3]     = sx; home[i3+1]     = sy; home[i3+2]     = z;
        positions[i3] = sx; positions[i3+1] = sy; positions[i3+2] = z;
        seed[w]    = Math.random();
        sizeMul[w] = 1 + (Math.random() - 0.5) * v;
        light[w]   = Math.random() - 0.5;
        w++;
      };
      for (let i = 0; i < idxMain.length; i++) {
        const k = idxMain[i] * 2;
        writePoint(samples.all[k], samples.all[k + 1]);
      }
      for (let i = 0; i < idxContour.length; i++) {
        const k = idxContour[i] * 2;
        writePoint(samples.contour[k], samples.contour[k + 1]);
      }

      this.count = count;
      this.home  = home;
      this.geometry = new THREE.BufferGeometry();
      this.geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      this.geometry.setAttribute('aSeed',    new THREE.BufferAttribute(seed, 1));
      this.geometry.setAttribute('aSizeMul', new THREE.BufferAttribute(sizeMul, 1));
      this.geometry.setAttribute('aLight',   new THREE.BufferAttribute(light, 1));

      this.material = new THREE.ShaderMaterial({
        uniforms: {
          uBaseSize:     { value: cfg.particles.baseSize },
          uSizeScale:    { value: 1 },
          uFadeNear:     { value: 0 },
          uFadeFar:      { value: 0 },
          uDepthFade:    { value: cfg.particles.depthFade },
          uInkColor:     { value: new THREE.Color(cfg.particles.inkColor) },
          uBgColor:      { value: new THREE.Color(cfg.scene.bgColor) },
          uLightnessVar: { value: cfg.particles.inkLightnessVar },
          uOpacity:      { value: cfg.particles.opacity },
        },
        vertexShader:   VERT,
        fragmentShader: FRAG,
        transparent: true,
        depthWrite:  false,
        depthTest:   false,
        blending:    THREE.NormalBlending,
      });

      this.points = new THREE.Points(this.geometry, this.material);
      this.points.frustumCulled = false;
    }
    dispose() {
      this.geometry.dispose();
      this.material.dispose();
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Simulator
  // ─────────────────────────────────────────────────────────────────────────
  class Simulator {
    constructor(particleSystem, cfg) {
      this.ps  = particleSystem;
      this.cfg = cfg;
    }
    step(dt, time, probe) {
      const pos  = this.ps.geometry.attributes.position.array;
      const seed = this.ps.geometry.attributes.aSeed.array;
      const vel  = this.ps.vel;
      const home = this.ps.home;
      const count = this.ps.count;

      const p   = this.cfg.physics;
      const ptr = this.cfg.pointer;

      const k    = p.springK;
      const dmp  = p.damping;
      const mode = p.ambientMode;
      const aOn  = mode !== 'off';
      const aSin = mode === 'sin';
      const aAmp = p.ambientAmp;
      const aFrq = p.ambientFreq;
      const maxV = p.maxVel,  maxV2 = maxV * maxV;
      const maxD = p.maxDisplacement, maxD2 = maxD * maxD;

      const probeActive = probe.active;
      const ox = probe.localOrigin.x, oy = probe.localOrigin.y, oz = probe.localOrigin.z;
      const rx = probe.localDir.x,    ry = probe.localDir.y,    rz = probe.localDir.z;
      const r  = ptr.radius,          r2 = r * r;
      const sign = ptr.mode === 'attract' ? -1 : 1;
      const str  = ptr.strength * sign;
      const useSmooth = ptr.falloff === 'smoothstep';

      for (let i = 0; i < count; i++) {
        const i3 = i * 3;
        const s = seed[i];

        let ax = 0, ay = 0, az = 0;
        if (aOn) {
          const a = time * aFrq + s * TAU;
          if (aSin) {
            ax = aAmp * Math.sin(a);
            ay = aAmp * Math.sin(a * 1.31 + 1.7);
            az = aAmp * 0.5 * Math.sin(a * 0.77 + 3.4);
          } else {
            ax = aAmp *  Math.sin(a * 1.1) * Math.cos(a * 0.7 + 1.0);
            ay = aAmp *  Math.cos(a * 0.9 + 2.0) * Math.sin(a * 1.3);
            az = aAmp * 0.5 * Math.sin(a + s * 5.0);
          }
        }
        const tx = home[i3]   + ax;
        const ty = home[i3+1] + ay;
        const tz = home[i3+2] + az;

        let fx = -k * (pos[i3]   - tx);
        let fy = -k * (pos[i3+1] - ty);
        let fz = -k * (pos[i3+2] - tz);

        if (probeActive) {
          const vx = pos[i3]   - ox;
          const vy = pos[i3+1] - oy;
          const vz = pos[i3+2] - oz;
          const proj = vx * rx + vy * ry + vz * rz;
          const perpX = vx - proj * rx;
          const perpY = vy - proj * ry;
          const perpZ = vz - proj * rz;
          const pd2 = perpX * perpX + perpY * perpY + perpZ * perpZ;
          if (pd2 < r2) {
            const pd = Math.sqrt(pd2) || 0.0001;
            const u = 1 - pd / r;
            const sm = useSmooth ? u * u * (3 - 2 * u) : u;
            const mag = (str * sm) / pd;
            fx += perpX * mag;
            fy += perpY * mag;
            fz += perpZ * mag;
          }
        }

        let vx = (vel[i3]   + fx * dt) * dmp;
        let vy = (vel[i3+1] + fy * dt) * dmp;
        let vz = (vel[i3+2] + fz * dt) * dmp;

        const v2 = vx * vx + vy * vy + vz * vz;
        if (v2 > maxV2) {
          const sv = maxV / Math.sqrt(v2);
          vx *= sv; vy *= sv; vz *= sv;
        }
        vel[i3] = vx; vel[i3+1] = vy; vel[i3+2] = vz;

        let nx = pos[i3]   + vx * dt;
        let ny = pos[i3+1] + vy * dt;
        let nz = pos[i3+2] + vz * dt;

        const odx = nx - home[i3];
        const ody = ny - home[i3+1];
        const odz = nz - home[i3+2];
        const od2 = odx * odx + ody * ody + odz * odz;
        if (od2 > maxD2) {
          const sd = maxD / Math.sqrt(od2);
          nx = home[i3]   + odx * sd;
          ny = home[i3+1] + ody * sd;
          nz = home[i3+2] + odz * sd;
        }
        pos[i3] = nx; pos[i3+1] = ny; pos[i3+2] = nz;
      }
      this.ps.geometry.attributes.position.needsUpdate = true;
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // Probe — cursor ray into local space.
  // ─────────────────────────────────────────────────────────────────────────
  class Probe {
    constructor(cfg) {
      this.cfg = cfg;
      this.raycaster   = new THREE.Raycaster();
      this.targetNDC   = new THREE.Vector2();
      this.smoothedNDC = new THREE.Vector2();
      this.localOrigin = new THREE.Vector3(1e6, 1e6, 1e6);
      this.localDir    = new THREE.Vector3(0, 0, -1);
      this.active = false;
      this._needSnap = false;
      this._invMat = new THREE.Matrix4();
    }
    setNDC(x, y) { this.targetNDC.set(x, y); }
    setActive(a) {
      if (a && !this.active) this._needSnap = true;
      this.active = a;
      if (!a) this.localOrigin.set(1e6, 1e6, 1e6);
    }
    update(camera, group) {
      if (!this.active) return;
      if (this._needSnap) {
        this.smoothedNDC.copy(this.targetNDC);
        this._needSnap = false;
      } else {
        this.smoothedNDC.lerp(this.targetNDC, this.cfg.pointer.smoothing);
      }
      this.raycaster.setFromCamera(this.smoothedNDC, camera);
      this._invMat.copy(group.matrixWorld).invert();
      this.localOrigin.copy(this.raycaster.ray.origin).applyMatrix4(this._invMat);
      this.localDir.copy(this.raycaster.ray.direction).transformDirection(this._invMat);
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // RotationController
  // ─────────────────────────────────────────────────────────────────────────
  class RotationController {
    constructor(cfg) {
      this.cfg = cfg;
      this.accumY = 0;
      this.parX = 0; this.parY = 0;
      this.tgtX = 0; this.tgtY = 0;
    }
    update(dt, time, group, pointerNDC, pointerActive) {
      const r = this.cfg.rotation;
      const baseY = r.mode === 'continuous'
        ? (this.accumY += r.speed * dt, this.accumY)
        : r.oscAngle * Math.sin(time * r.oscFreq);
      if (r.parallax && pointerActive) {
        this.tgtY =  pointerNDC.x * r.parallaxAmount;
        this.tgtX = -pointerNDC.y * r.parallaxAmount;
      } else {
        this.tgtX *= 0.94; this.tgtY *= 0.94;
      }
      this.parX += (this.tgtX - this.parX) * r.parallaxLerp;
      this.parY += (this.tgtY - this.parY) * r.parallaxLerp;
      group.rotation.y = baseY + this.parY;
      group.rotation.x = this.parX;
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // LoadIn
  // ─────────────────────────────────────────────────────────────────────────
  class LoadIn {
    constructor(particleSystem, cfg) {
      this.ps  = particleSystem;
      this.cfg = cfg;
      this.active = false;
      this.startTime = 0;
      this.starts = new Float32Array(particleSystem.count * 3);
      this.delays = new Float32Array(particleSystem.count);
      this.onComplete = null;
    }
    prepare() {
      const home  = this.ps.home;
      const count = this.ps.count;
      const vol   = this.cfg.loadIn.startVolume;
      const mode  = this.cfg.loadIn.staggerMode;
      const total = this.cfg.loadIn.stagger;

      let minX = Infinity, maxX = -Infinity, maxR = 0;
      for (let i = 0; i < count; i++) {
        const i3 = i * 3;
        const x = home[i3];
        if (x < minX) minX = x;
        if (x > maxX) maxX = x;
        const rr = Math.hypot(home[i3], home[i3 + 1]);
        if (rr > maxR) maxR = rr;
      }
      const xRange = (maxX - minX) || 1;
      maxR = maxR || 1;

      for (let i = 0; i < count; i++) {
        const i3 = i * 3;
        this.starts[i3]     = (Math.random() - 0.5) * vol;
        this.starts[i3 + 1] = (Math.random() - 0.5) * vol;
        this.starts[i3 + 2] = (Math.random() - 0.5) * vol * 0.5;
        if (mode === 'leftToRight') {
          this.delays[i] = ((home[i3] - minX) / xRange) * total;
        } else if (mode === 'centreOut') {
          const rr = Math.hypot(home[i3], home[i3 + 1]);
          this.delays[i] = (rr / maxR) * total;
        } else {
          this.delays[i] = Math.random() * total;
        }
      }
    }
    start(time) {
      this.prepare();
      this.startTime = time;
      this.active = true;
      this.ps.vel.fill(0);
      const pos = this.ps.geometry.attributes.position.array;
      pos.set(this.starts);
      this.ps.geometry.attributes.position.needsUpdate = true;
    }
    step(time) {
      const dur   = this.cfg.loadIn.duration;
      const total = dur + this.cfg.loadIn.stagger;
      const t     = time - this.startTime;
      const ease  = easings[this.cfg.loadIn.easing] || easings.easeOutCubic;
      const pos   = this.ps.geometry.attributes.position.array;
      const home  = this.ps.home;
      const starts = this.starts;
      const delays = this.delays;
      const count  = this.ps.count;

      for (let i = 0; i < count; i++) {
        const lt = (t - delays[i]) / dur;
        const u = lt <= 0 ? 0 : lt >= 1 ? 1 : ease(lt);
        const i3 = i * 3;
        const inv = 1 - u;
        pos[i3]     = starts[i3]     * inv + home[i3]     * u;
        pos[i3 + 1] = starts[i3 + 1] * inv + home[i3 + 1] * u;
        pos[i3 + 2] = starts[i3 + 2] * inv + home[i3 + 2] * u;
      }
      this.ps.geometry.attributes.position.needsUpdate = true;

      if (t >= total) {
        this.active = false;
        pos.set(home);
        this.ps.vel.fill(0);
        this.ps.geometry.attributes.position.needsUpdate = true;
        if (this.onComplete) this.onComplete();
      }
    }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // PostFX
  // ─────────────────────────────────────────────────────────────────────────
  const VignetteGrainShader = {
    uniforms: {
      tDiffuse:  { value: null },
      uVignette: { value: 0 },
      uGrain:    { value: 0 },
      uTime:     { value: 0 },
      uBgColor:  { value: new THREE.Color('#FFFFFF') },
    },
    vertexShader: `
      varying vec2 vUv;
      void main(){
        vUv = uv;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      precision highp float;
      uniform sampler2D tDiffuse;
      uniform float uVignette;
      uniform float uGrain;
      uniform float uTime;
      uniform vec3  uBgColor;
      varying vec2 vUv;
      float hash(vec2 p){ return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453); }
      void main() {
        vec4 c = texture2D(tDiffuse, vUv);
        vec2 uv = vUv - 0.5;
        float d2 = dot(uv, uv);
        float vig = smoothstep(0.18, 0.78, d2) * uVignette;
        vec3 vigColor = uBgColor * 0.78;
        c.rgb = mix(c.rgb, vigColor, vig);
        float g = (hash(vUv * 1024.0 + uTime) - 0.5) * uGrain;
        c.rgb += g;
        gl_FragColor = c;
      }
    `,
  };

  class PostFX {
    constructor(renderer, scene, camera, cfg) {
      this.composer = new EffectComposer(renderer);
      this.composer.addPass(new RenderPass(scene, camera));

      this.vig = new ShaderPass(VignetteGrainShader);
      this.vig.uniforms.uVignette.value = cfg.post.vignette;
      this.vig.uniforms.uGrain.value    = cfg.post.grain;
      this.vig.uniforms.uBgColor.value.set(cfg.scene.bgColor);
      this.composer.addPass(this.vig);

      this.rgb = new ShaderPass(RGBShiftShader);
      this.rgb.uniforms.amount.value = cfg.post.chromaticAberration;
      this.composer.addPass(this.rgb);
    }
    setSize(w, h) { this.composer.setSize(w, h); }
    setTime(t)    { this.vig.uniforms.uTime.value = t; }
    render()      { this.composer.render(); }
  }

  // ─────────────────────────────────────────────────────────────────────────
  // HERO — three.js setup
  // ─────────────────────────────────────────────────────────────────────────
  const canvas = document.getElementById('c');
  const scrollCueEl = document.getElementById('scrollCue');
  const siteNavEl = document.querySelector('.site-nav');

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
  renderer.setPixelRatio(Math.min(2, window.devicePixelRatio));
  renderer.setSize(window.innerWidth, window.innerHeight, false);
  renderer.setClearColor(new THREE.Color(CONFIG.scene.bgColor));
  renderer.outputColorSpace = THREE.SRGBColorSpace;

  const scene = new THREE.Scene();
  scene.background = new THREE.Color(CONFIG.scene.bgColor);

  const camera = new THREE.PerspectiveCamera(
    CONFIG.scene.cameraFov,
    window.innerWidth / window.innerHeight,
    0.1, 100,
  );
  camera.position.set(0, 0, CONFIG.scene.cameraDistance);
  camera.lookAt(0, 0, 0);

  const group = new THREE.Group();
  scene.add(group);

  const sampler     = new GlyphSampler();
  const probe       = new Probe(CONFIG);
  const rotationCtl = new RotationController(CONFIG);

  let particleSystem = null;
  let simulator      = null;
  let loadIn         = null;

  const postFX = new PostFX(renderer, scene, camera, CONFIG);
  postFX.setSize(window.innerWidth, window.innerHeight);

  function setSizeScale() {
    if (!particleSystem) return;
    const target = new THREE.Vector2();
    renderer.getDrawingBufferSize(target);
    particleSystem.material.uniforms.uSizeScale.value = target.y * 0.5;
  }

  function updateFadeRange() {
    if (!particleSystem) return;
    const camZ = CONFIG.scene.cameraDistance;
    const halfExtent = CONFIG.glyph.worldHeight * 0.5 + CONFIG.glyph.depth * 0.5 + 0.4;
    particleSystem.material.uniforms.uFadeNear.value = camZ - halfExtent;
    particleSystem.material.uniforms.uFadeFar.value  = camZ + halfExtent;
  }

  async function buildSystem() {
    if (particleSystem) {
      group.remove(particleSystem.points);
      particleSystem.dispose();
    }
    const samples = await sampler.sample(CONFIG);
    particleSystem = new ParticleSystem(samples, CONFIG);
    group.add(particleSystem.points);
    simulator = new Simulator(particleSystem, CONFIG);
    loadIn = new LoadIn(particleSystem, CONFIG);
    loadIn.onComplete = () => {
      setTimeout(() => {
        if (siteNavEl) siteNavEl.classList.add('in');
        scrollCueEl.classList.add('in');
        // Phase 2 listeners can latch onto this to fade in section reveals etc.
        window.dispatchEvent(new CustomEvent('hero:loaded'));
      }, CONFIG.loadIn.uiFadeDelay * 1000);
    };
    setSizeScale();
    updateFadeRange();
    loadIn.start(clock.elapsedTime);
  }

  const pointerNDC = new THREE.Vector2();
  let pointerActive = false;

  window.addEventListener('pointermove', (e) => {
    if (!heroVisible) return;
    const x =  (e.clientX / window.innerWidth)  * 2 - 1;
    const y = -(e.clientY / window.innerHeight) * 2 + 1;
    pointerNDC.set(x, y);
    probe.setNDC(x, y);
    probe.setActive(true);
    pointerActive = true;
  });
  window.addEventListener('pointerleave', () => {
    probe.setActive(false);
    pointerActive = false;
  });

  window.addEventListener('resize', () => {
    const w = window.innerWidth, h = window.innerHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h, false);
    postFX.setSize(w, h);
    setSizeScale();
  });

  const clock = new THREE.Clock();
  clock.getDelta();

  await buildSystem();
  // Tuning GUI is opt-in (append ?tune to the URL) — never shown in production.
  if (new URLSearchParams(location.search).has('tune')) setupGUI();

  // ─── Hero render loop with visibility-gated rAF ────────────────────
  let heroVisible = true;
  let rafId = null;

  function tick() {
    rafId = null;
    const dt = Math.min(clock.getDelta(), 1 / 30);
    const t  = clock.elapsedTime;

    if (CONFIG.scene.cameraDriftEnabled) {
      const a = CONFIG.scene.cameraDriftAmp;
      const s = CONFIG.scene.cameraDriftSpeed;
      camera.position.x = a * Math.sin(t * s);
      camera.position.y = a * Math.sin(t * s * 0.7 + 1.3) * 0.6;
    } else {
      camera.position.x = 0;
      camera.position.y = 0;
    }
    camera.position.z = CONFIG.scene.cameraDistance;
    camera.lookAt(0, 0, 0);

    rotationCtl.update(dt, t, group, pointerNDC, pointerActive);
    group.updateMatrixWorld();
    probe.update(camera, group);

    if (loadIn.active)  loadIn.step(t);
    else if (simulator) simulator.step(dt, t, probe);

    postFX.setTime(t);
    postFX.render();

    if (heroVisible) rafId = requestAnimationFrame(tick);
  }
  tick();

  // Pause the WebGL loop when the hero is fully off-screen.
  const heroSectionEl = document.querySelector('.hero-section');
  new IntersectionObserver(([entry]) => {
    if (entry.isIntersecting) {
      if (!heroVisible) {
        heroVisible = true;
        clock.getDelta();
        if (rafId === null) tick();
      }
    } else {
      heroVisible = false;
      probe.setActive(false);
    }
  }, { threshold: 0 }).observe(heroSectionEl);

  // ─────────────────────────────────────────────────────────────────────────
  // GUI
  // ─────────────────────────────────────────────────────────────────────────
  function setupGUI() {
    const gui = new GUI({ title: 'CG tuning', width: 320 });

    const fScene = gui.addFolder('Scene');
    fScene.addColor(CONFIG.scene, 'bgColor').onChange(v => {
      const c = new THREE.Color(v);
      renderer.setClearColor(c);
      scene.background = c;
      document.documentElement.style.setProperty('--bg', v);
      if (particleSystem) particleSystem.material.uniforms.uBgColor.value.set(c);
      if (postFX) postFX.vig.uniforms.uBgColor.value.set(c);
    });
    fScene.add(CONFIG.scene, 'cameraDistance', 3, 30, 0.05).onChange(() => updateFadeRange());
    fScene.add(CONFIG.scene, 'cameraFov', 20, 70, 1).onChange(v => {
      camera.fov = v; camera.updateProjectionMatrix();
    });
    fScene.add(CONFIG.scene, 'cameraDriftEnabled');
    fScene.add(CONFIG.scene, 'cameraDriftAmp',   0, 0.3, 0.005);
    fScene.add(CONFIG.scene, 'cameraDriftSpeed', 0, 2,   0.01);

    const fParticles = gui.addFolder('Particles');
    fParticles.add(CONFIG.particles, 'count', 40000, 200000, 1000)
      .onFinishChange(() => buildSystem());
    fParticles.add(CONFIG.particles, 'contourBoost', 0, 0.15, 0.005)
      .onFinishChange(() => buildSystem());
    fParticles.add(CONFIG.particles, 'baseSize', 0.005, 0.2, 0.001)
      .onChange(v => particleSystem.material.uniforms.uBaseSize.value = v);
    fParticles.add(CONFIG.particles, 'sizeVariance', 0, 1.5, 0.01)
      .onFinishChange(() => buildSystem());
    fParticles.add(CONFIG.glyph, 'depth', 0.05, 1.5, 0.01)
      .onFinishChange(() => { buildSystem(); updateFadeRange(); });
    fParticles.add(CONFIG.particles, 'opacity', 0.1, 1.0, 0.01)
      .onChange(v => particleSystem.material.uniforms.uOpacity.value = v);
    fParticles.add(CONFIG.particles, 'depthFade', 0, 1, 0.01)
      .onChange(v => particleSystem.material.uniforms.uDepthFade.value = v);
    fParticles.add(CONFIG.particles, 'inkLightnessVar', 0, 0.2, 0.005)
      .onChange(v => particleSystem.material.uniforms.uLightnessVar.value = v);
    fParticles.addColor(CONFIG.particles, 'inkColor').onChange(v => {
      particleSystem.material.uniforms.uInkColor.value.set(v);
    });

    const fPhysics = gui.addFolder('Physics');
    fPhysics.add(CONFIG.physics, 'springK', 1, 80, 0.5);
    fPhysics.add(CONFIG.physics, 'damping', 0.5, 0.99, 0.005);
    fPhysics.add(CONFIG.physics, 'maxVel', 0.5, 25, 0.1);
    fPhysics.add(CONFIG.physics, 'maxDisplacement', 0.1, 4, 0.05);
    fPhysics.add(CONFIG.physics, 'ambientMode', ['off', 'sin', 'curl']);
    fPhysics.add(CONFIG.physics, 'ambientAmp', 0, 0.1, 0.001);
    fPhysics.add(CONFIG.physics, 'ambientFreq', 0, 3, 0.01);

    const fPointer = gui.addFolder('Pointer');
    fPointer.add(CONFIG.pointer, 'mode', ['repel', 'attract']);
    fPointer.add(CONFIG.pointer, 'radius', 0.05, 1.5, 0.01);
    fPointer.add(CONFIG.pointer, 'strength', 0, 50, 0.5);
    fPointer.add(CONFIG.pointer, 'falloff', ['smoothstep', 'linear']);
    fPointer.add(CONFIG.pointer, 'smoothing', 0.02, 1.0, 0.01);

    const fRot = gui.addFolder('Rotation');
    fRot.add(CONFIG.rotation, 'mode', ['continuous', 'oscillate']);
    fRot.add(CONFIG.rotation, 'speed', 0, 1.5, 0.01);
    fRot.add(CONFIG.rotation, 'oscAngle', 0, 1.5, 0.01);
    fRot.add(CONFIG.rotation, 'oscFreq', 0, 1.5, 0.01);
    fRot.add(CONFIG.rotation, 'parallax');
    fRot.add(CONFIG.rotation, 'parallaxAmount', 0, 0.5, 0.01);
    fRot.add(CONFIG.rotation, 'parallaxLerp', 0.005, 0.2, 0.005);

    const fLoad = gui.addFolder('Load-in');
    fLoad.add(CONFIG.loadIn, 'duration', 0.3, 4, 0.05);
    fLoad.add(CONFIG.loadIn, 'stagger',  0,   3, 0.05);
    fLoad.add(CONFIG.loadIn, 'staggerMode', ['leftToRight', 'centreOut', 'random']);
    fLoad.add(CONFIG.loadIn, 'easing', ['easeOutCubic', 'easeOutExpo', 'easeInOutCubic', 'linear']);
    fLoad.add(CONFIG.loadIn, 'startVolume', 2, 15, 0.1);

    const fPost = gui.addFolder('Post');
    fPost.add(CONFIG.post, 'grain', 0, 0.2, 0.001)
      .onChange(v => postFX.vig.uniforms.uGrain.value = v);
    fPost.add(CONFIG.post, 'vignette', 0, 1.5, 0.01)
      .onChange(v => postFX.vig.uniforms.uVignette.value = v);
    fPost.add(CONFIG.post, 'chromaticAberration', 0, 0.02, 0.0001)
      .onChange(v => postFX.rgb.uniforms.amount.value = v);

    const actions = {
      replay: () => {
        if (siteNavEl) siteNavEl.classList.remove('in');
        scrollCueEl.classList.remove('in');
        loadIn.start(clock.elapsedTime);
      },
      logConfig: () => console.log(JSON.stringify(CONFIG, null, 2)),
    };
    gui.add(actions, 'replay').name('Replay load-in');
    gui.add(actions, 'logConfig').name('Log CONFIG as JSON');

    [fScene, fParticles, fPhysics, fPointer, fRot, fLoad, fPost].forEach(f => f.close());
    gui.close();
  }
</script>
