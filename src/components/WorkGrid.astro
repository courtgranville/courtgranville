---
// The Swiss project gallery. Per spec §11:
//   - Desktop (12-col): three 4-col tiles per row.
//   - Tablet (8-col):   two 4-col tiles per row.
//   - Mobile (4-col):   one full-width tile per row.
//
// Per tile: hero image (placeholder for now — real photography in Phase 3),
// Playfair name 24/32, Raleway-caps meta line below.
//
// Marginalia:
//   - Thin hairline (#E5E5E5) along the bottom of each tile row.
//   - Small Raleway-caps row number in the outer margin, visible at tablet
//     and desktop only. CSS counter scoped per breakpoint so the row index
//     stays correct as the column count changes.
//
// Order: most recent first. The Nuclear Question is excluded — it lives on
// the blog/thesis track per spec §11.

import Grid from './Grid.astro';
import imageManifest from '../content/projects-images.json';

function heroFor(slug: string, heroSlug: string) {
  const manifest = (imageManifest as Record<string, { images: any[] }>)[slug];
  return manifest?.images.find((i) => i.slug === heroSlug) ?? null;
}

const PROJECTS = [
  { name: 'Mantis',                  year: 2026, discipline: 'Product Design',            slug: 'mantis',               hero: heroFor('mantis', '04-final-hero') },
  { name: 'Wave',                    year: 2026, discipline: 'Product Design',            slug: 'wave',                 hero: heroFor('wave', '03-final-hero') },
  { name: 'Gravity Wave Backgammon', year: 2024, discipline: 'Product Design',            slug: 'backgammon',           hero: heroFor('backgammon', '07-final-hero') },
  { name: 'LUMI',                    year: 2023, discipline: 'Critical / Product Design', slug: 'lumi',                 hero: heroFor('lumi', '04-final-hero') },
  { name: 'YourPAL',                 year: 2023, discipline: 'App Design / UX·UI',        slug: 'yourpal',              hero: heroFor('yourpal', '04-final-hero') },
  { name: 'Spider-209',              year: 2022, discipline: 'Product Design',            slug: 'spider-209',           hero: heroFor('spider-209', '04-final') },
  { name: 'Universal Phone Case',    year: 2022, discipline: 'Product Design',            slug: 'universal-phone-case', hero: heroFor('universal-phone-case', '07-final-hero') },
];
---
<Grid as="section" class="work-grid" aria-label="Project gallery">
  {PROJECTS.map((p, i) => (
    <a class="work-tile reveal" href={`/work/${p.slug}/`}>
      {p.hero ? (
        <div class="tile-media">
          <img
            src={p.hero.src}
            srcset={p.hero.srcset}
            sizes="(min-width: 1200px) 30vw, (min-width: 768px) 45vw, 100vw"
            alt={`${p.name} — ${p.discipline}`}
            loading={i < 3 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      ) : (
        <div class="tile-media placeholder">
          <span class="tile-ph">{p.name}</span>
        </div>
      )}
      <div class="tile-meta">
        <h2 class="tile-name">{p.name}</h2>
        <div class="tile-line">{p.year} &middot; {p.discipline}</div>
      </div>
    </a>
  ))}
</Grid>

<style>
  .work-grid {
    counter-reset: work-row;
    row-gap: clamp(48px, 6vh, 80px);
    padding-block: clamp(40px, 6vh, 80px) clamp(80px, 14vh, 140px);
  }

  .work-tile {
    grid-column: 1 / -1;
    position: relative;
    display: block;
    color: var(--text);
    padding-bottom: 32px;
    border-bottom: 1px solid var(--hairline);
  }

  /* Tablet — 4-col tiles in an 8-col grid (two per row). */
  @media (min-width: 768px) {
    .work-tile { grid-column: span 4; }
    .work-tile:nth-child(2n+1) { counter-increment: work-row; }
    .work-tile:nth-child(2n+1)::before {
      content: counter(work-row, decimal-leading-zero);
      position: absolute;
      top: 4px;
      left: -56px;
      font-family: var(--sans);
      font-weight: 500;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--text-faint);
    }
  }

  /* Desktop — 4-col tiles in a 12-col grid (three per row). The counter
   * resets implicitly via the cascade. */
  @media (min-width: 1200px) {
    .work-tile:nth-child(2n+1)::before,
    .work-tile:nth-child(2n+1) { counter-increment: unset; }
    .work-tile:nth-child(2n+1)::before { content: none; }

    .work-tile:nth-child(3n+1) { counter-increment: work-row; }
    .work-tile:nth-child(3n+1)::before {
      content: counter(work-row, decimal-leading-zero);
      position: absolute;
      top: 4px;
      left: -64px;
      font-family: var(--sans);
      font-weight: 500;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--text-faint);
    }
  }

  /* Image area — placeholder block now, real photography in Phase 3. The
   * 3:4 aspect is a sensible default for portrait-leaning product work and
   * stays consistent across the row. */
  .tile-media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #3F3D38;
    display: grid;
    place-items: center;
    transition: transform 400ms var(--ease-out);
  }
  .tile-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tile-ph {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(24px, 2.6vw, 36px);
    color: rgba(255, 255, 255, 0.30);
    line-height: 1.1;
    text-align: center;
    padding: 0 24px;
  }

  /* Hover — restrained: a 2% image scale, name shifts to deep red. */
  .work-tile:hover .tile-media { transform: scale(1.02); }
  .work-tile:hover .tile-name  { color: var(--accent); }

  .tile-meta {
    padding-top: 20px;
  }
  .tile-name {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 24px;
    line-height: 32px;
    color: var(--text);
    margin: 0 0 8px;
    transition: color var(--dur-hover) var(--ease-out);
  }
  .tile-line {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 12px;
    line-height: 16px;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--text-quiet);
  }

  /* Focus state: aligns with the global focus-visible (via outline) — no
   * additional treatment needed beyond keeping the tile keyboard-reachable. */

  @media (prefers-reduced-motion: reduce) {
    .tile-media,
    .tile-name { transition: none; }
    .work-tile:hover .tile-media { transform: none; }
  }
</style>
