---
// Work index — a typographic project list paired with the shared 3D image
// field. Reusable: `side` mirrors the pairing (visual right on /work/, visual
// left on the homepage Screen 2). One fixed orientation per placement; it does
// not alternate. Hover a project NAME (or focus it) to preview its hero in the
// field. Field contract per §3 (fixed 3:2, contain, flat, tilt-on-interaction).

import Grid from './Grid.astro';
import imageManifest from '../content/projects-images.json';

export interface Props {
  side?: 'left' | 'right';
  kicker?: string;
}
const { side = 'right', kicker } = Astro.props;

function heroFor(slug: string, heroSlug: string) {
  const manifest = (imageManifest as Record<string, { images: any[] }>)[slug];
  const img = manifest?.images.find((i) => i.slug === heroSlug);
  if (!img) return null;
  return { src: img.src.replace('-2400.webp', '-1200.webp'), aspect: img.aspect as number };
}

const PROJECTS = [
  { name: 'Mantis',                  year: 2026, discipline: 'Product Design',            slug: 'mantis',               hero: heroFor('mantis', '04-final-hero') },
  { name: 'Wave',                    year: 2026, discipline: 'Product Design',            slug: 'wave',                 hero: heroFor('wave', '03-final-hero') },
  { name: 'Gravity Wave Backgammon', year: 2024, discipline: 'Product Design',            slug: 'backgammon',           hero: heroFor('backgammon', '07-final-hero') },
  { name: 'LUMI',                    year: 2023, discipline: 'Critical / Product Design', slug: 'lumi',                 hero: heroFor('lumi', '04-final-hero') },
  { name: 'YourPAL',                 year: 2023, discipline: 'App Design / UX·UI',        slug: 'yourpal',              hero: heroFor('yourpal', '04-final-hero') },
  { name: 'Spider-209',              year: 2022, discipline: 'Product Design',            slug: 'spider-209',           hero: heroFor('spider-209', '04-final') },
  { name: 'Universal Phone Case',    year: 2022, discipline: 'Product Design',            slug: 'universal-phone-case', hero: heroFor('universal-phone-case', '07-final-hero') },
];

const clientData = PROJECTS.map((p) => ({ name: p.name, year: p.year, discipline: p.discipline, hero: p.hero }));
const textTrack   = side === 'left' ? 't-text-r'   : 't-text-l';
const visualTrack = side === 'left' ? 't-visual-l' : 't-visual-r';
---
<Grid as="section" class="work-index" aria-label="Selected work">
  {kicker && <span class="label wi-kicker reveal">{kicker}</span>}

  <!-- Visual first in the DOM so mobile stacks field-above-text (§2.4); on
       desktop the track classes place text and field by column regardless. -->
  <div class:list={['wi-visual', visualTrack, 'reveal']} data-stagger="1">
    <div class="field">
      <canvas id="wiCanvas" aria-hidden="true"></canvas>
    </div>
  </div>

  <div class:list={['wi-list', textTrack, 'reveal']} data-stagger="2">
    <ul class="wi-rows">
      {PROJECTS.map((p, i) => (
        <li class="wi-row" data-i={i}>
          <a href={`/work/${p.slug}/`}>
            <span class="wi-num label">{String(i + 1).padStart(2, '0')}</span>
            <span class="wi-name">{p.name}</span>
            <span class="wi-year label">{p.year}</span>
            <span class="wi-disc label">{p.discipline}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Grid>

<script type="application/json" id="wiData" is:inline set:html={JSON.stringify(clientData)}></script>

<style>
  /* dense so the list (earlier column) sits beside the visual even though the
     visual is first in the DOM (kept first for the mobile stack). */
  :global(.work-index) { row-gap: var(--space-block); align-items: start; grid-auto-flow: dense; }

  .wi-kicker { grid-column: 1 / -1; display: block; }

  .wi-rows { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--rule); }
  .wi-row { border-bottom: 1px solid var(--rule); }
  .wi-row a {
    display: grid;
    grid-template-columns: 2.4rem 1fr auto;
    grid-template-areas: 'num name year' 'num disc disc';
    align-items: baseline;
    column-gap: 1rem;
    row-gap: 4px;
    padding: clamp(14px, 1.6vh, 20px) 0;
    color: var(--text);
    transition: padding-left var(--dur-hover) var(--ease-out), color var(--dur-hover) var(--ease-out);
  }
  .wi-num  { grid-area: num;  color: var(--text-faint); }
  .wi-name { grid-area: name; font-family: var(--serif); font-weight: 400;
             font-size: var(--fs-heading-m); line-height: var(--lh-heading-m); width: fit-content; }
  .wi-year { grid-area: year; color: var(--text-quiet); font-variant-numeric: tabular-nums; }
  .wi-disc { grid-area: disc; color: var(--text-faint); }

  .wi-row a:hover,
  .wi-row.active a { color: var(--accent); padding-left: clamp(6px, 1vw, 14px); }
  .wi-row.active .wi-num,
  .wi-row.active .wi-disc { color: rgba(142, 27, 14, 0.7); }

  @media (prefers-reduced-motion: reduce) {
    .wi-row a { transition: none; }
  }
</style>

<script is:inline type="module">
  import { mountHeroCanvas } from '/js/hero-canvas.js';

  const data   = JSON.parse(document.getElementById('wiData').textContent);
  const canvas = document.getElementById('wiCanvas');
  const rows   = Array.from(document.querySelectorAll('.wi-row'));

  const api = mountHeroCanvas(canvas);          // field-contract defaults (flat, tilt-on-hover)
  api.preload(data.map((d) => d.hero && d.hero.src));

  function select(i) {
    rows.forEach((r, k) => r.classList.toggle('active', k === i));
    api.show(data[i].hero);
  }
  rows.forEach((r) => {
    const i = Number(r.dataset.i);
    r.querySelector('.wi-name').addEventListener('pointerenter', () => select(i));   // mouse
    r.querySelector('a').addEventListener('focusin', () => select(i));               // keyboard
  });
  select(0);

  // Touch / no-hover: drive the preview from whichever row is crossing the
  // viewport's vertical centre, so the index works without a mouse. Tapping a
  // row still navigates to the project (the <a> is untouched).
  if (matchMedia('(hover: none), (pointer: coarse)').matches) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) if (e.isIntersecting) select(Number(e.target.dataset.i));
    }, { rootMargin: '-45% 0px -45% 0px', threshold: 0 });
    rows.forEach((r) => io.observe(r));
  }
</script>
