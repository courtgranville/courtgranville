---
// Two side-by-side equal cells with a gutter between. Spec §8: cols 2 / 12
// at desktop. Mobile stacks them.

export interface Props {
  images: Array<{ src: string; srcset?: string; aspect?: number | null }>;
  alt: string;
}
const { images, alt } = Astro.props;
---
<section class="block">
  <div class="pair">
    {images.map((img) => (
      <figure class="figure">
        <img
          src={img.src}
          srcset={img.srcset}
          sizes="(min-width: 1200px) 40vw, (min-width: 768px) 45vw, 100vw"
          alt={alt}
          loading="lazy"
          decoding="async"
          style={img.aspect ? `aspect-ratio: ${img.aspect};` : ''}
        />
      </figure>
    ))}
  </div>
</section>

<style>
  .block {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    column-gap: var(--gutter);
    padding-inline: var(--outer);
    margin: clamp(40px, 6vh, 64px) 0;
  }
  .pair {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gutter);
  }
  .figure { margin: 0; }
  .figure img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    background: var(--hairline);
  }

  @media (min-width: 768px) {
    .pair { grid-column: 1 / 9; }
  }
  @media (min-width: 1200px) {
    .pair { grid-column: 2 / 12; }
  }
</style>
