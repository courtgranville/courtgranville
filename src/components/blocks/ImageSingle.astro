---
// Single image. Three variants per spec §8:
//   narrow (3/9)   — inline reading-width
//   wide   (2/12)  — bleeds to outer margin
//   bleed  (1/-1)  — edge-to-edge of the viewport, breaks the grid
//
// `aspect` lets the browser reserve space (no CLS) and the srcset gives the
// browser two widths to pick from. lazy + async are on for all but the
// first image of a page (the route can opt the hero out via `priority`).

export interface Props {
  src: string;
  srcset?: string;
  alt: string;
  caption?: string;
  variant?: 'narrow' | 'wide' | 'bleed';
  aspect?: number | null;
  priority?: boolean;
}
const {
  src,
  srcset,
  alt,
  caption,
  variant = 'wide',
  aspect = null,
  priority = false,
} = Astro.props;

const sizes =
  variant === 'bleed'  ? '100vw'
  : variant === 'wide'  ? '(min-width: 1200px) 80vw, 100vw'
  : '(min-width: 1200px) 50vw, 100vw';

const aspectStyle = aspect ? `aspect-ratio: ${aspect};` : '';
---
<section class:list={['block', `block--${variant}`]}>
  <figure class="figure">
    <img
      src={src}
      srcset={srcset}
      sizes={sizes}
      alt={alt}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={priority ? 'high' : 'auto'}
      style={aspectStyle}
    />
    {caption && <figcaption class="label">{caption}</figcaption>}
  </figure>
</section>

<style>
  .block {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    column-gap: var(--gutter);
    padding-inline: var(--outer);
    margin: clamp(40px, 6vh, 64px) 0;
  }
  .block--bleed {
    padding-inline: 0;
    /* The bleed block ignores the grid container's outer margin and stretches
     * to viewport edges. */
  }
  .figure {
    grid-column: 1 / -1;
    margin: 0;
  }
  .figure img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    background: var(--hairline);
  }
  figcaption {
    margin-top: 12px;
    color: var(--text-quiet);
  }

  @media (min-width: 768px) {
    .block--narrow .figure { grid-column: 2 / 8; }
    .block--wide   .figure { grid-column: 1 / 9; }
  }
  @media (min-width: 1200px) {
    .block--narrow .figure { grid-column: 3 / 9; }
    .block--wide   .figure { grid-column: 2 / 12; }
  }
</style>
