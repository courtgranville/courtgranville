---
// Pull quote — Playfair italic, offset right. Spec §8: cols 5 / 12 at
// desktop. Sits as a counterweight to the left-anchored body prose.

export interface Props {
  body: string;
  attribution?: string;
}
const { body, attribution } = Astro.props;
---
<section class="block">
  <blockquote class="quote">
    <p set:html={body} />
    {attribution && <cite class="label">{attribution}</cite>}
  </blockquote>
</section>

<style>
  .block {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    column-gap: var(--gutter);
    padding-inline: var(--outer);
    margin: clamp(48px, 7vh, 72px) 0;
  }
  .quote {
    grid-column: 1 / -1;
    margin: 0;
  }
  .quote p {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: var(--fs-pull);
    line-height: var(--lh-pull);
    color: var(--text);
    margin: 0;
  }
  cite {
    display: block;
    margin-top: 16px;
    color: var(--text-quiet);
    font-style: normal;
  }
  @media (min-width: 768px) {
    .quote { grid-column: 3 / 8; }
  }
  @media (min-width: 1200px) {
    .quote { grid-column: 5 / 12; }
  }
</style>
