---
// Raleway-caps margin kicker — `01 / EXPLORATION`. Spec §8: cols 1 / 3 at
// desktop; collapses to full-width at mobile so it still announces the
// section without crowding the body type.

export interface Props {
  text: string;
}
const { text } = Astro.props;
---
<section class="block">
  <span class="label kicker">{text}</span>
</section>

<style>
  .block {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    column-gap: var(--gutter);
    padding-inline: var(--outer);
    margin-top: clamp(48px, 7vh, 80px);
    margin-bottom: 16px;
  }
  .kicker {
    grid-column: 1 / -1;
    color: var(--text-quiet);
  }
  @media (min-width: 768px) {
    .kicker { grid-column: 1 / 3; }
  }
</style>
