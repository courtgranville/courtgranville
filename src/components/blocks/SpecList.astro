---
// Factual sidebar block — year, discipline, tools, materials. Spec §8: cols
// 9 / 13 at desktop (the right four columns), tucked alongside body prose.

export interface Props {
  entries: Record<string, string>;
}
const { entries } = Astro.props;
---
<section class="block">
  <dl class="spec">
    {Object.entries(entries).map(([k, v]) => (
      <>
        <dt class="label">{k}</dt>
        <dd>{v}</dd>
      </>
    ))}
  </dl>
</section>

<style>
  .block {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    column-gap: var(--gutter);
    padding-inline: var(--outer);
    margin: clamp(24px, 4vh, 48px) 0;
  }
  .spec {
    grid-column: 1 / -1;
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px var(--gutter);
    align-items: baseline;
  }
  dt {
    color: var(--text-quiet);
    white-space: nowrap;
  }
  dd {
    margin: 0;
    font-family: var(--sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text);
  }

  @media (min-width: 768px) {
    .spec { grid-column: 5 / 9; }
  }
  @media (min-width: 1200px) {
    .spec { grid-column: 9 / 13; }
  }
</style>
