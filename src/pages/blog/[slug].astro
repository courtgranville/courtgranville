---
// Blog post template. Renders frontmatter header + markdown body on the grid.
// Drafts build only in dev (excluded from production via import.meta.env.PROD),
// so the framework is testable before any post is published.

import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Grid from '../../components/Grid.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, draft } = post.data;
const fmt = (d: Date) => d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title={`${title} — Court Granville`} description={description}>
  <Nav />
  <main>
    <article class="post">
      <Grid class="post-head">
        <span class="label post-meta">
          {fmt(pubDate)}{draft ? ' · Draft' : ''}{tags.length ? ` · ${tags.join(' / ')}` : ''}
        </span>
        <h1 class="post-name">{title}</h1>
        <p class="post-desc">{description}</p>
      </Grid>

      <Grid class="post-body">
        <div class="prose"><Content /></div>
      </Grid>

      <Grid class="post-foot">
        {updatedDate && <span class="label post-updated">Updated {fmt(updatedDate)}</span>}
        <a class="all-posts" href="/blog/">&larr; All posts</a>
      </Grid>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  article { padding-top: calc(var(--nav-h) + clamp(40px, 7vh, 96px)); }
  .post-head { margin-bottom: clamp(32px, 5vh, 56px); }
  .post-meta, .post-name, .post-desc { grid-column: 1 / -1; }
  .post-meta { display: block; color: var(--text-quiet); margin-bottom: 16px; }
  .post-name { font-family: var(--serif); font-weight: 400; font-size: clamp(34px, 5vw, 60px);
    line-height: 1.08; color: var(--text); margin: 0 0 20px; }
  .post-desc { font-family: var(--serif); font-style: italic; font-size: clamp(19px, 2.2vw, 24px);
    line-height: 1.45; color: var(--text); margin: 0; max-width: 56ch; }

  .prose { grid-column: 1 / -1; }
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol) { font-size: var(--fs-body); line-height: var(--lh-body); color: var(--text);
    max-width: 64ch; margin: 0 0 var(--baseline-3); }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.3em; }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(h2) { font-family: var(--serif); font-weight: 400; font-size: clamp(24px, 2.8vw, 34px);
    line-height: 1.2; margin: var(--baseline-6) 0 var(--baseline-2); }
  .prose :global(h3) { font-family: var(--serif); font-weight: 400; font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.25; margin: var(--baseline-4) 0 var(--baseline-2); }
  .prose :global(blockquote) { margin: var(--baseline-4) 0; padding-left: 24px;
    border-left: 2px solid var(--accent); font-family: var(--serif); font-style: italic;
    font-size: clamp(20px, 2.4vw, 28px); line-height: 1.4; color: var(--text); max-width: 50ch; }
  .prose :global(a) { color: var(--accent); border-bottom: 1px solid var(--accent); }
  .prose :global(code) { font-family: ui-monospace, monospace; font-size: 0.9em;
    background: rgba(22,22,22,0.05); padding: 1px 5px; border-radius: 3px; }
  .prose :global(img) { width: 100%; height: auto; margin: var(--baseline-4) 0; }

  .post-foot { margin-top: clamp(64px, 12vh, 120px); padding-top: clamp(28px, 4vh, 48px);
    border-top: 1px solid var(--rule); padding-bottom: clamp(48px, 6vh, 72px); }
  .post-updated { grid-column: 1 / -1; display: block; color: var(--text-faint); margin-bottom: 12px; }
  .all-posts { grid-column: 1 / -1; font-family: var(--sans); font-weight: 500; font-size: 12px;
    letter-spacing: var(--ls-label); text-transform: uppercase; color: var(--text-quiet); }
  .all-posts:hover { color: var(--accent); }

  @media (min-width: 768px) {
    .post-meta { grid-column: 1 / 3; }
    .post-name { grid-column: 3 / 9; }
    .post-desc { grid-column: 3 / 9; }
    .prose     { grid-column: 3 / 9; }
    .post-foot :global(*) { }
    .all-posts { grid-column: 3 / 9; }
    .post-updated { grid-column: 3 / 9; }
  }
  @media (min-width: 1200px) {
    .post-name { grid-column: 3 / 11; }
    .post-desc { grid-column: 3 / 10; }
    .prose     { grid-column: 3 / 9; }
    .all-posts { grid-column: 3 / 9; }
    .post-updated { grid-column: 3 / 9; }
  }
</style>

<style is:global>
  main { position: relative; z-index: 2; }
</style>
