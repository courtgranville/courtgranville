---
// Writing — the index. Published (non-draft) posts list here automatically;
// drafts show in dev only. Conformed to the type roles + named tracks (§6.6).

import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Grid from '../../components/Grid.astro';

const posts = (await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) => d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="Writing — Court Granville" description="Notes on design, trust, and contested technology — the writing track of the site.">
  <Nav />
  <main>
    <Grid as="section" class="blog">
      <span class="label t-rail blog-kicker reveal">Writing</span>
      <h1 class="t-body blog-lead reveal" data-stagger="1">Design, trust, and contested technology.</h1>

      <ul class="t-body post-list reveal" data-stagger="2">
        {posts.map((p) => (
          <li class="post-row">
            <a href={`/blog/${p.id.replace(/\.(md|mdx)$/, '')}/`}>
              <span class="post-date label">{fmt(p.data.pubDate)}{p.data.draft ? ' · draft' : ''}</span>
              <span class="post-title">{p.data.title}</span>
              <span class="post-desc">{p.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </Grid>
  </main>
  <Footer />
</Layout>

<style>
  :global(.blog) {
    padding-block: calc(var(--nav-h) + var(--space-page-top)) var(--space-section);
    row-gap: var(--space-block);
    align-items: start;
  }
  .blog-kicker { display: block; }
  .blog-lead {
    font-family: var(--serif); font-weight: 400;
    font-size: var(--fs-display-l); line-height: var(--lh-display-l);
    color: var(--text); margin: 0; max-width: 16ch;
  }

  .post-list { list-style: none; margin: 0; padding: 0; }
  .post-row { border-top: 1px solid var(--rule); }
  .post-row:last-child { border-bottom: 1px solid var(--rule); }
  .post-row a { display: grid; gap: 6px; padding: clamp(18px,2.4vh,28px) 0; color: var(--text);
    transition: padding-left var(--dur-hover) var(--ease-out); }
  .post-row a:hover { padding-left: 10px; }
  .post-date { display: block; color: var(--text-faint); }
  .post-title {
    font-family: var(--serif); font-weight: 400;
    font-size: var(--fs-heading-m); line-height: var(--lh-heading-m);
    transition: color var(--dur-hover) var(--ease-out);
  }
  .post-row a:hover .post-title { color: var(--accent); }
  .post-desc { font-size: var(--fs-body-s); line-height: var(--lh-body-s); color: var(--text-quiet); max-width: 56ch; }
</style>

<style is:global>
  main { position: relative; z-index: 2; }
</style>
