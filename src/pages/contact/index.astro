---
// Contact — deliberately spare: the email is the surface. Social links are
// left out until Court supplies real URLs (no dead placeholders).

import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Grid from '../../components/Grid.astro';
---
<Layout title="Contact — Court Granville" description="Get in touch with Court Granville — open to roles, freelance and collaborations in technology, energy and other technical fields. London & Madrid.">
  <Nav />
  <main>
    <Grid as="article" class="contact">
      <span class="label contact-kicker reveal">Contact</span>
      <h1 class="contact-lead reveal" data-stagger="1">
        Got a role, a project, or just want to talk about design? The fastest way to reach me is email.
      </h1>
      <a class="contact-email reveal" data-stagger="2" href="mailto:court@courtgranville.com">court@courtgranville.com</a>
      <p class="contact-avail reveal" data-stagger="3">
        I&rsquo;m open to roles, freelance and collaborations &mdash; particularly in
        technology, energy and other technical fields where design can do real work.
      </p>
      <p class="label contact-types reveal" data-stagger="4">Job opportunity &middot; Freelance project &middot; General</p>
      <p class="label contact-loc reveal" data-stagger="4">London &amp; Madrid</p>
    </Grid>
  </main>
  <Footer />
</Layout>

<style>
  :global(.contact) {
    padding-block: calc(var(--nav-h) + clamp(64px, 14vh, 180px)) clamp(80px, 16vh, 200px);
    row-gap: clamp(24px, 4vh, 40px);
  }
  .contact-kicker { grid-column: 1 / -1; display: block; }
  .contact-lead {
    grid-column: 1 / -1;
    font-family: var(--serif); font-weight: 400;
    font-size: var(--fs-display-l); line-height: var(--lh-display-l); color: var(--text);
    margin: 0; max-width: 22ch;
  }
  .contact-email {
    grid-column: 1 / -1;
    font-family: var(--serif); font-weight: 400;
    font-size: var(--fs-heading-m); line-height: var(--lh-heading-m); color: var(--text);
    border-bottom: 1px solid var(--rule); padding-bottom: 6px; width: fit-content;
    transition: color var(--dur-hover) var(--ease-out), border-color var(--dur-hover) var(--ease-out);
  }
  .contact-email:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .contact-avail {
    grid-column: 1 / -1;
    font-size: var(--fs-body); line-height: var(--lh-body); color: var(--text-quiet);
    margin: 0; max-width: 52ch;
  }
  .contact-types { grid-column: 1 / -1; display: block; margin-top: 8px; }
  .contact-loc { grid-column: 1 / -1; display: block; margin-top: 4px; color: var(--text-faint); }

  @media (min-width: 768px) {
    .contact-kicker { grid-column: 1 / 3; }
    .contact-lead   { grid-column: 3 / 9; }
    .contact-email  { grid-column: 3 / 9; }
    .contact-avail  { grid-column: 3 / 9; }
    .contact-types  { grid-column: 3 / 9; }
    .contact-loc    { grid-column: 3 / 9; }
  }
  @media (min-width: 1200px) {
    .contact-lead  { grid-column: 3 / 10; }
    .contact-email { grid-column: 3 / 12; }
    .contact-avail { grid-column: 3 / 9; }
    .contact-types { grid-column: 3 / 10; }
    .contact-loc   { grid-column: 3 / 10; }
  }
</style>

<style is:global>
  main { position: relative; z-index: 2; }
</style>
