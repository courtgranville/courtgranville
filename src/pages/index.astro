---
// Homepage. The CG particle hero is the first screen — large and borderless,
// the fixed full-window canvas as Court designed it, with a small text
// complement anchored lower-left. Selected Work + the thesis band sit below in
// an opaque layer that scrolls up over the fixed canvas.

import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import WorkIndex from '../components/WorkIndex.astro';
import Footer from '../components/Footer.astro';
import Grid from '../components/Grid.astro';
---
<Layout title="Court Granville">
  <Nav />
  <main>
    <h1 class="sr-only">Court Granville — Product &amp; Interaction Designer, Madrid</h1>

    <!-- Screen 1 — the CG particle hero, full screen, with a small complement. -->
    <Hero>
      <p class="hero-statement reveal">I&rsquo;m a product designer working where things turn technical &mdash; making complexity clear enough to trust, and to act on.</p>
      <a class="textlink hero-cta reveal" data-stagger="1" href="/work/">View work &rarr;</a>
    </Hero>

    <!-- Below the hero — opaque, occludes the fixed canvas as it scrolls up. -->
    <div class="hp-below">
      <section class="hp-section" aria-label="Selected work">
        <WorkIndex side="left" kicker="01 — Selected Work" />
        <Grid>
          <a class="textlink hp-allwork reveal" href="/work/">All work &rarr;</a>
        </Grid>
      </section>

      <section class="hp-section hp-thesis" aria-label="Thesis">
        <Grid>
          <div class="t-body hp-thesis-inner reveal">
            <h2 class="hp-thesis-h">The Nuclear Question</h2>
            <p class="hp-thesis-p">A thesis on how strategic communication shapes public trust in contested technology.</p>
            <a class="textlink" href="/blog/">Read the thesis &rarr;</a>
          </div>
        </Grid>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  /* Small text complement to the hero (slotted into .hero-overlay). */
  .hero-statement {
    font-family: var(--serif);
    font-weight: 400;
    font-size: var(--fs-body);
    line-height: 1.5;
    color: var(--text);
    margin: 0 0 16px;
  }
  .hero-cta { font-size: var(--fs-label); }

  /* Everything after the hero rides above the fixed canvas on a white ground. */
  .hp-below {
    position: relative;
    z-index: 2;
    background: var(--bg);
  }
  .hp-section { padding-block: var(--space-section); }

  .hp-allwork { grid-column: 1 / -1; margin-top: var(--space-block); justify-self: start; }

  .hp-thesis { border-top: 1px solid var(--rule); }
  .hp-thesis-inner { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
  .hp-thesis-h {
    font-family: var(--serif); font-weight: 400;
    font-size: var(--fs-heading-m); line-height: var(--lh-heading-m);
    color: var(--text); margin: 0;
  }
  .hp-thesis-p {
    font-size: var(--fs-body); line-height: var(--lh-body);
    color: var(--text-quiet); max-width: 56ch; margin: 0;
  }
</style>

<style is:global>
  /* main establishes the stacking context that contains the fixed hero canvas
     (z-index 1); its opaque sections (hp-below) then occlude it on scroll. */
  main { position: relative; z-index: 2; }
</style>
