---
// Homepage. The CG particle hero is the first screen — large and borderless,
// its canvas confined to the hero so it lives at the top only (it scrolls away
// with the first screen rather than sitting as a fixed layer behind the page).
// A small text complement is anchored lower-left; Selected Work + the thesis
// band follow in normal flow.

import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Carousel from '../components/Carousel.astro';
import Footer from '../components/Footer.astro';
import Grid from '../components/Grid.astro';
---
<Layout
  title="Court Granville — Multidisciplinary Designer"
  description="Court Granville is a multidisciplinary designer working across product, interaction, data visualisation and the web — translating complex, contested subjects into things people can understand and use. London & Madrid."
>
  <Nav />
  <main>
    <h1 class="sr-only">Court Granville — Multidisciplinary Designer, London &amp; Madrid</h1>

    <!-- Screen 1 — the CG particle hero, full screen, with a small complement. -->
    <Hero>
      <p class="hero-statement reveal">Making the technical legible, useful and beautiful.</p>
      <a class="textlink hero-cta reveal" data-stagger="1" href="/work/">View work &rarr;</a>
    </Hero>

    <!-- Below the hero — opaque, occludes the fixed canvas as it scrolls up. -->
    <div class="hp-below">
      <section class="hp-section hp-intro" aria-label="Introduction">
        <Grid>
          <span class="label hp-intro-kicker reveal">Multidisciplinary Designer</span>
          <p class="hp-intro-pos reveal" data-stagger="1">Design is the translation layer between technical complexity and the people it&rsquo;s meant to serve.</p>
          <p class="hp-intro-lead reveal" data-stagger="2">I&rsquo;m a multidisciplinary designer working across product, interaction, data and the web. My training is in product design, but a pull toward technology, AI and systems has taken me wider &mdash; toward the industries where design is needed most, and the contested subjects in between.</p>
        </Grid>
      </section>

      <section class="hp-section" aria-label="Selected work">
        <Carousel />
        <Grid>
          <a class="textlink hp-allwork reveal" href="/work/">All work &rarr;</a>
        </Grid>
      </section>

      <section class="hp-section hp-writing" aria-label="Writing">
        <Grid>
          <div class="t-body hp-writing-inner reveal">
            <span class="label">Writing</span>
            <p class="hp-writing-p">I write about strategic communication and the public perception of contested technologies &mdash; what makes messaging credible, persuasive and honest. It began with my thesis on nuclear energy, and it&rsquo;s turning into something ongoing.</p>
            <a class="textlink" href="/blog/">Read the writing &rarr;</a>
          </div>
        </Grid>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  /* Small text complement to the hero (slotted into .hero-overlay). */
  .hero-statement {
    font-family: var(--serif);
    font-weight: 400;
    font-size: var(--fs-body);
    line-height: 1.5;
    color: var(--text);
    margin: 0 0 16px;
  }
  .hero-cta { font-size: var(--fs-label); }

  /* Everything after the hero, on the white ground, in normal flow. */
  .hp-below {
    position: relative;
    z-index: 2;
    background: var(--bg);
  }
  .hp-section { padding-block: var(--space-section); }

  /* Intro band — the positioning statement (display serif) over a supporting
     sub-line, both on the shared grid. Mirrors the About statement/body ranges. */
  :global(.hp-intro) { row-gap: clamp(20px, 3vh, 36px); align-items: start; }
  .hp-intro-kicker { grid-column: 1 / -1; display: block; }
  .hp-intro-pos {
    grid-column: 1 / -1;
    font-family: var(--serif); font-weight: 400;
    font-size: var(--fs-display-l); line-height: var(--lh-display-l);
    color: var(--text); margin: 0; max-width: 22ch;
  }
  .hp-intro-lead {
    grid-column: 1 / -1;
    font-size: var(--fs-body); line-height: var(--lh-body);
    color: var(--text-quiet); margin: 0; max-width: 58ch;
  }
  @media (min-width: 768px) {
    .hp-intro-kicker { grid-column: 1 / 3; }
    .hp-intro-pos    { grid-column: 3 / 9; }
    .hp-intro-lead   { grid-column: 3 / 8; }
  }
  @media (min-width: 1200px) {
    .hp-intro-pos    { grid-column: 3 / 11; }
    .hp-intro-lead   { grid-column: 3 / 9; }
  }

  .hp-allwork { grid-column: 1 / -1; margin-top: var(--space-block); justify-self: start; }

  .hp-writing { border-top: 1px solid var(--rule); }
  .hp-writing-inner { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
  .hp-writing-inner .label { color: var(--text-quiet); }
  .hp-writing-p {
    font-size: var(--fs-body); line-height: var(--lh-body);
    color: var(--text-quiet); max-width: 56ch; margin: 0;
  }
</style>

<style is:global>
  /* main is the page's positioned wrapper; sections stack in normal flow. */
  main { position: relative; z-index: 2; }
</style>
