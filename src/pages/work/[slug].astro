---
// Project page template (§6.3). The flat block array is grouped into sections
// at each `label` boundary, then each section is rendered on the shared grid by
// kind:
//   prose   — label on Rail, text on Body. Not a split.
//   gallery — label on Rail, text on Body, the grid/pair/extra images on Wide.
//   split   — exactly one single image + its text: text on the split-text track,
//             image in the visual field on the split-visual track. Consumes an
//             alternation index and toggles side.
//
// The header is itself the first split (visual RIGHT, split-index 0), so the
// first body split takes the left. Image slugs resolve against the per-project
// manifest (projects-images.json). A cyclic "Next →" closes the page.

import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Grid from '../../components/Grid.astro';

import imageManifest from '../../content/projects-images.json';

// Canonical order — most-recent-first; matches the Work index.
const ORDER = [
  'mantis',
  'wave',
  'backgammon',
  'lumi',
  'yourpal',
  'spider-209',
  'universal-phone-case',
];

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.id.replace(/\.json$/, '') },
    props: { project: p },
  }));
}

const { project } = Astro.props as { project: Awaited<ReturnType<typeof getCollection<'projects'>>>[number] };
const { name, year, discipline, framing, spec, exhibitions, blocks, heroImage } = project.data;

const slug = project.id.replace(/\.json$/, '');
const manifest = (imageManifest as any)[slug];

function img(imgSlug: string) {
  const entry = manifest?.images.find((i: any) => i.slug === imgSlug);
  if (!entry) {
    throw new Error(`Missing image for ${slug}/${imgSlug} — re-run scripts/process-images.mjs`);
  }
  return entry;
}

const hero = img(heroImage);

// ── Group the flat block array into sections, classify, assign split sides ──
type Block = (typeof blocks)[number];
interface Section {
  label: string | null;
  items: Block[];
  kind: 'prose' | 'gallery' | 'split';
  side?: 'left' | 'right';
}

const sections: Section[] = [];
let current: Section | null = null;
for (const b of blocks) {
  if (b.type === 'label') {
    current = { label: b.text, items: [], kind: 'prose' };
    sections.push(current);
  } else {
    if (!current) { current = { label: null, items: [], kind: 'prose' }; sections.push(current); }
    current.items.push(b);
  }
}

const isVisual = (b: Block) => b.type === 'image' || b.type === 'imageGrid' || b.type === 'imagePair';

// Classify, and alternate split sides. The header took split-index 0 (visual
// right), so the first body split is index 1 → visual left, then toggling.
let splitIdx = 1;
for (const s of sections) {
  const visuals = s.items.filter(isVisual);
  const singleImages = s.items.filter((b) => b.type === 'image');
  if (visuals.length === 0) s.kind = 'prose';
  else if (visuals.length === 1 && singleImages.length === 1) s.kind = 'split';
  else s.kind = 'gallery';

  if (s.kind === 'split') {
    s.side = splitIdx % 2 === 0 ? 'right' : 'left';
    splitIdx++;
  }
}

// Next-project navigation (cyclic).
const idx = ORDER.indexOf(slug);
const nextSlug = idx >= 0 && idx < ORDER.length - 1 ? ORDER[idx + 1] : ORDER[0];
const allProjects = await getCollection('projects');
const nextProject = allProjects.find((p) => p.id.replace(/\.json$/, '') === nextSlug);
const nextName = nextProject?.data.name ?? '';
---
<Layout title={`${name} — Court Granville`} description={framing}>
  <Nav />
  <main>
    <article>
      <!-- Header — the first split (visual RIGHT, split-index 0). Visual first
           in the DOM so mobile stacks field-above-text (§2.4). -->
      <Grid class="proj-head">
        <div class="t-visual-r proj-head-visual reveal">
          <div class="field">
            <img
              src={hero.src}
              srcset={hero.srcset}
              sizes="(min-width: 1200px) 58vw, 100vw"
              alt={`${name} — hero`}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        </div>
        <div class="t-text-l proj-head-text reveal" data-stagger="1">
          <span class="label proj-meta">{discipline} &middot; {year}</span>
          <h1 class="proj-name">{name}</h1>
          <p class="proj-framing">{framing}</p>
          {spec && (
            <dl class="spec-table proj-spec">
              {Object.entries(spec).map(([k, v]) => (
                <>
                  <dt>{k}</dt>
                  <dd>{v}</dd>
                </>
              ))}
            </dl>
          )}
          {exhibitions && (
            <div class="proj-exhibitions">
              <span class="label">Exhibited</span>
              <ul>
                {exhibitions.map((line) => <li>{line}</li>)}
              </ul>
            </div>
          )}
        </div>
      </Grid>

      <!-- Body sections -->
      {sections.map((s) => {
        const texts = s.items.filter((b) => b.type === 'text');

        if (s.kind === 'split') {
          const single = s.items.find((b) => b.type === 'image')!;
          const m = img(single.imageSlug);
          const visualTrack = s.side === 'right' ? 't-visual-r' : 't-visual-l';
          const textTrack   = s.side === 'right' ? 't-text-l'   : 't-text-r';
          return (
            <Grid class="proj-section proj-split">
              <div class:list={[visualTrack, 'proj-split-visual', 'reveal']}>
                <div class="field">
                  <img
                    src={m.src}
                    srcset={m.srcset}
                    sizes="(min-width: 1200px) 58vw, 100vw"
                    alt={single.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                {single.caption && <figcaption class="label proj-cap">{single.caption}</figcaption>}
              </div>
              <div class:list={[textTrack, 'proj-split-text', 'reveal']} data-stagger="1">
                {s.label && <span class="label proj-seclabel">{s.label}</span>}
                {texts.map((t) => <p class="proj-prose" set:html={t.body} />)}
              </div>
            </Grid>
          );
        }

        // prose + gallery share the Rail-label / Body-text head; gallery adds visuals on Wide.
        return (
          <Grid class:list={['proj-section', s.kind === 'gallery' ? 'proj-gallery' : 'proj-prose-sec']}>
            {s.label && <span class="label t-rail proj-seclabel reveal">{s.label}</span>}
            {texts.length > 0 && (
              <div class="t-body proj-body reveal" data-stagger="1">
                {texts.map((t) => <p class="proj-prose" set:html={t.body} />)}
              </div>
            )}
            {s.kind === 'gallery' && s.items.filter(isVisual).map((v) => {
              if (v.type === 'image') {
                const m = img(v.imageSlug);
                return (
                  <figure class="t-wide g-figure reveal">
                    <img
                      src={m.src}
                      srcset={m.srcset}
                      sizes="(min-width: 1200px) 80vw, 100vw"
                      alt={v.alt}
                      loading="lazy"
                      decoding="async"
                      style={m.aspect ? `aspect-ratio: ${m.aspect};` : ''}
                    />
                    {v.caption && <figcaption class="label proj-cap">{v.caption}</figcaption>}
                  </figure>
                );
              }
              if (v.type === 'imagePair') {
                const imgs = v.imageSlugs.map(img);
                return (
                  <div class="t-wide g-pair reveal">
                    {imgs.map((m: any) => (
                      <img
                        src={m.src}
                        srcset={m.srcset}
                        sizes="(min-width: 1200px) 40vw, (min-width: 768px) 45vw, 100vw"
                        alt={v.alt}
                        loading="lazy"
                        decoding="async"
                        style={m.aspect ? `aspect-ratio: ${m.aspect};` : ''}
                      />
                    ))}
                  </div>
                );
              }
              // imageGrid
              const imgs = v.imageSlugs.map(img);
              return (
                <div class:list={['t-wide', 'g-grid', `up-${imgs.length}`, 'reveal']}>
                  {imgs.map((m: any) => (
                    <img
                      src={m.src}
                      srcset={m.srcset}
                      sizes={imgs.length >= 3
                        ? '(min-width: 1200px) 30vw, (min-width: 768px) 45vw, 100vw'
                        : '(min-width: 1200px) 40vw, (min-width: 768px) 45vw, 100vw'}
                      alt={v.alt}
                      loading="lazy"
                      decoding="async"
                      style={m.aspect ? `aspect-ratio: ${m.aspect};` : ''}
                    />
                  ))}
                </div>
              );
            })}
          </Grid>
        );
      })}

      <Grid class="proj-foot">
        <a class="next-link" href={`/work/${nextSlug}/`}>
          <span class="label next-label">Next project</span>
          <span class="next-name">{nextName} &rarr;</span>
        </a>
        <a class="all-work label" href="/work/">&larr; All work</a>
      </Grid>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  article { padding-top: calc(var(--nav-h) + var(--space-page-top)); }

  /* ── Header split ─────────────────────────────────────────────────────── */
  /* Grid roots render inside <Grid> and miss this file's scope hash → :global. */
  :global(.proj-head) {
    align-items: center;
    grid-auto-flow: dense;       /* visual is first in DOM; text packs left */
    row-gap: var(--space-block);
  }
  .proj-head-text { display: flex; flex-direction: column; gap: 16px; }
  .proj-meta { color: var(--text-quiet); }
  .proj-name {
    font-family: var(--serif); font-weight: 400;
    font-size: var(--fs-display-l); line-height: var(--lh-display-l);
    color: var(--text); margin: 0;
  }
  .proj-framing {
    font-family: var(--serif); font-weight: 400; font-style: italic;
    font-size: var(--fs-heading-s); line-height: var(--lh-heading-s);
    color: var(--text); margin: 0; max-width: 40ch;
  }
  .proj-spec { margin-top: 8px; }
  .proj-exhibitions { margin-top: 8px; }
  .proj-exhibitions ul {
    list-style: none; margin: 8px 0 0; padding: 0;
    display: flex; flex-direction: column; gap: 6px;
  }
  .proj-exhibitions li {
    font-size: var(--fs-body-s); line-height: var(--lh-body-s); color: var(--text);
  }

  /* ── Body sections ────────────────────────────────────────────────────── */
  :global(.proj-section) {
    margin-top: var(--space-section);
    row-gap: var(--space-block);
    align-items: start;
  }
  :global(.proj-split) {
    align-items: center;
    grid-auto-flow: dense;       /* visual first in DOM; text packs to its side */
  }

  .proj-seclabel { color: var(--text-quiet); align-self: start; }
  .proj-split-text { display: flex; flex-direction: column; gap: 16px; }

  .proj-prose {
    font-family: var(--sans); font-weight: 400;
    font-size: var(--fs-body); line-height: var(--lh-body);
    color: var(--text); max-width: 62ch; margin: 0;
  }
  .proj-body { display: flex; flex-direction: column; gap: var(--space-block); }

  /* Gallery visuals — natural aspect, contained, never cropped. */
  .g-figure { margin: 0; }
  .g-figure img,
  .g-pair img,
  .g-grid img {
    width: 100%; height: auto; display: block;
    object-fit: contain; background: var(--field-bg);
  }
  .proj-cap { display: block; margin-top: 12px; color: var(--text-quiet); }

  .g-pair, .g-grid { display: grid; gap: var(--gutter); grid-template-columns: 1fr; }
  @media (min-width: 768px) {
    .g-pair, .g-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1200px) {
    .g-pair { grid-template-columns: 1fr 1fr; }
    .g-grid.up-2 { grid-template-columns: 1fr 1fr; }
    .g-grid.up-3 { grid-template-columns: 1fr 1fr 1fr; }
    .g-grid.up-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }
  }

  /* ── Footer nav ───────────────────────────────────────────────────────── */
  :global(.proj-foot) {
    margin-top: var(--space-section);
    padding-bottom: clamp(48px, 6vh, 72px);
    border-top: 1px solid var(--rule);
    padding-top: var(--space-block);
  }
  .next-link, .all-work { grid-column: 1 / -1; display: block; }
  .next-label { display: block; color: var(--text-quiet); margin-bottom: 8px; }
  .next-name {
    font-family: var(--serif); font-weight: 400;
    font-size: var(--fs-heading-m); line-height: var(--lh-heading-m);
    color: var(--text); transition: color var(--dur-hover) var(--ease-out);
  }
  .next-link:hover .next-name { color: var(--accent); }
  .all-work { margin-top: 24px; color: var(--text-quiet); }
  .all-work:hover { color: var(--accent); }

  @media (min-width: 768px) {
    .next-link { grid-column: 1 / 6; }
    .all-work  { grid-column: 7 / 9; margin-top: 0; align-self: end; }
  }
  @media (min-width: 1200px) {
    .next-link { grid-column: 1 / 8; }
    .all-work  { grid-column: 10 / 13; margin-top: 0; align-self: end; }
  }
</style>

<style is:global>
  main { position: relative; z-index: 2; }
</style>
