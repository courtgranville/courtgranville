---
// Project page template. Renders the frontmatter header (project name +
// framing line + discipline · year meta) then iterates the block array.
//
// Image-block image slugs are resolved against the per-project image manifest
// (src/content/projects-images.json) so the JSON stays terse while srcset and
// aspect ratios are filled in at render time.
//
// A "Next →" link at the foot of every page points to the next project in
// the canonical Work order, so the visitor can travel through the catalogue
// without bouncing back to the index.

import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Grid from '../../components/Grid.astro';

import SectionLabel from '../../components/blocks/SectionLabel.astro';
import Text from '../../components/blocks/Text.astro';
import PullQuote from '../../components/blocks/PullQuote.astro';
import ImageSingle from '../../components/blocks/ImageSingle.astro';
import ImagePair from '../../components/blocks/ImagePair.astro';
import ImageGrid from '../../components/blocks/ImageGrid.astro';
import SpecList from '../../components/blocks/SpecList.astro';

import imageManifest from '../../content/projects-images.json';

// Canonical order — most-recent-first; matches WorkGrid.astro.
const ORDER = [
  'mantis',
  'wave',
  'backgammon',
  'lumi',
  'yourpal',
  'spider-209',
  'universal-phone-case',
];

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.id.replace(/\.json$/, '') },
    props: { project: p },
  }));
}

const { project } = Astro.props as { project: Awaited<ReturnType<typeof getCollection<'projects'>>>[number] };
const { name, year, discipline, framing, spec, exhibitions, blocks, heroImage } = project.data;

const slug = project.id.replace(/\.json$/, '');
const manifest = (imageManifest as any)[slug];

// Resolve an image slug into a manifest entry. The manifest is generated by
// scripts/process-images.mjs; if a referenced slug is missing, fail loudly.
function img(imgSlug: string) {
  const entry = manifest?.images.find((i: any) => i.slug === imgSlug);
  if (!entry) {
    throw new Error(`Missing image for ${slug}/${imgSlug} — re-run scripts/process-images.mjs`);
  }
  return entry;
}

const hero = img(heroImage);

// Next-project navigation.
const idx = ORDER.indexOf(slug);
const nextSlug = idx >= 0 && idx < ORDER.length - 1 ? ORDER[idx + 1] : ORDER[0];
const allProjects = await getCollection('projects');
const nextProject = allProjects.find((p) => p.id === `${nextSlug}.json`);
const nextName = nextProject?.data.name ?? '';
---
<Layout title={`${name} — Court Granville`} description={framing}>
  <Nav />
  <main>
    <article>
      <!-- Header — Playfair Display project name, framing line below, meta
           strip at top. Built on the grid so it shares the page rhythm. -->
      <Grid class="project-head">
        <span class="label project-meta">{discipline} &middot; {year}</span>
        <h1 class="project-name">{name}</h1>
        <p class="project-framing">{framing}</p>
      </Grid>

      <!-- Hero image — full-bleed, eager-loaded (first paint matters). -->
      <ImageSingle
        src={hero.src}
        srcset={hero.srcset}
        alt={`${name} — hero`}
        variant="bleed"
        aspect={hero.aspect}
        priority={true}
      />

      <!-- Spec list and exhibitions, if present. Rendered after the hero so
           the page opens on the image, not the table. -->
      {spec && <SpecList entries={spec} />}
      {exhibitions && (
        <SpecList
          entries={Object.fromEntries(
            exhibitions.map((line, i) => [`Exhibition ${String(i + 1).padStart(2, '0')}`, line])
          )}
        />
      )}

      {blocks.map((block) => {
        if (block.type === 'label')      return <SectionLabel text={block.text} />;
        if (block.type === 'text')       return <Text body={block.body} />;
        if (block.type === 'quote')      return <PullQuote body={block.body} attribution={block.attribution} />;
        if (block.type === 'specList')   return <SpecList entries={block.entries} />;
        if (block.type === 'image') {
          const m = img(block.imageSlug);
          return (
            <ImageSingle
              src={m.src}
              srcset={m.srcset}
              alt={block.alt}
              caption={block.caption}
              variant={block.variant}
              aspect={m.aspect}
            />
          );
        }
        if (block.type === 'imagePair') {
          const a = img(block.imageSlugs[0]);
          const b = img(block.imageSlugs[1]);
          return <ImagePair alt={block.alt} images={[a, b]} />;
        }
        if (block.type === 'imageGrid') {
          const imgs = block.imageSlugs.map(img);
          return <ImageGrid alt={block.alt} images={imgs} />;
        }
        return null;
      })}

      <Grid class="project-foot">
        <a class="next-link" href={`/work/${nextSlug}/`}>
          <span class="label next-label">Next project</span>
          <span class="next-name">{nextName} &rarr;</span>
        </a>
        <a class="all-work" href="/work/">&larr; All work</a>
      </Grid>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  article {
    padding-top: calc(var(--nav-h) + clamp(40px, 6vh, 72px));
  }

  .project-head {
    margin-bottom: clamp(32px, 5vh, 56px);
  }

  .project-meta,
  .project-name,
  .project-framing {
    grid-column: 1 / -1;
  }

  .project-meta {
    display: block;
    color: var(--text-quiet);
    margin-bottom: 16px;
  }

  .project-name {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.08;
    color: var(--text);
    margin: 0 0 24px;
  }

  .project-framing {
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.45;
    color: var(--text);
    margin: 0;
    max-width: 56ch;
  }

  @media (min-width: 768px) {
    .project-meta    { grid-column: 1 / 3; }
    .project-name    { grid-column: 3 / 9; }
    .project-framing { grid-column: 3 / 9; }
  }

  @media (min-width: 1200px) {
    .project-meta    { grid-column: 1 / 3; }
    .project-name    { grid-column: 3 / 12; }
    .project-framing { grid-column: 3 / 10; }
  }

  /* Footer nav — sit on the grid, with the "Next" link as the editorial
   * weight and "All work" as a quiet secondary path. */
  .project-foot {
    margin-top: clamp(80px, 14vh, 140px);
    padding-bottom: clamp(48px, 6vh, 72px);
    border-top: 1px solid var(--rule);
    padding-top: clamp(32px, 5vh, 56px);
  }
  .next-link,
  .all-work {
    grid-column: 1 / -1;
    display: block;
  }
  .next-label {
    display: block;
    color: var(--text-quiet);
    margin-bottom: 8px;
  }
  .next-name {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.1;
    color: var(--text);
    transition: color var(--dur-hover) var(--ease-out);
  }
  .next-link:hover .next-name { color: var(--accent); }
  .all-work {
    margin-top: 24px;
    font-family: var(--sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--text-quiet);
  }
  .all-work:hover { color: var(--accent); }

  @media (min-width: 768px) {
    .next-link { grid-column: 1 / 6; }
    .all-work  { grid-column: 7 / 9; margin-top: 0; align-self: end; }
  }
  @media (min-width: 1200px) {
    .next-link { grid-column: 1 / 8; }
    .all-work  { grid-column: 10 / 13; margin-top: 0; align-self: end; }
  }
</style>

<style is:global>
  main { position: relative; z-index: 2; }
</style>
