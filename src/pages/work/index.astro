---
// Work — the project index. A typographic list paired with a 3D image canvas
// (WorkIndex) that previews each project's hero on hover. The grid is the page.

import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import WorkIndex from '../../components/WorkIndex.astro';
---
<Layout title="Work — Court Granville" description="Selected projects by Court Granville.">
  <Nav />
  <main>
    <WorkIndex />
  </main>
  <Footer />
</Layout>

<style is:global>
  main {
    position: relative;
    z-index: 2;
  }
</style>
