---
// Work — the project index. The grid is the page: a typographic list paired
// with the shared 3D image field (WorkIndex), visual on the right.

import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import WorkIndex from '../../components/WorkIndex.astro';
---
<Layout title="Work — Court Granville" description="Selected projects by Court Granville.">
  <Nav />
  <main class="work-main">
    <h1 class="sr-only">Work</h1>
    <WorkIndex side="right" kicker="Work" />
  </main>
  <Footer />
</Layout>

<style>
  .work-main {
    padding-block: calc(var(--nav-h) + var(--space-page-top)) var(--space-section);
  }
</style>

<style is:global>
  main { position: relative; z-index: 2; }
</style>
